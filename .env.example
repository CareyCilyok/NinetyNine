# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# The app uses email + password authentication with mandatory email verification
# (no third-party OAuth). In production the SMTP settings below must be filled in
# so verification and password-reset emails can be delivered.
#
# In local development, leaving these blank is fine — the app falls back to the
# ConsoleEmailSender which logs verification/reset links to the container logs
# (follow with `./deploy.sh logs web`) instead of actually sending email.
#
# For production, supply a real SMTP provider (Postmark, SendGrid, AWS SES,
# Fastmail, or self-hosted — MailKit will work with any of them).
EMAIL_PROVIDER=Console
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@example.com
SMTP_FROM_NAME=NinetyNine
SMTP_USE_STARTTLS=true

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local dev: pre-configured to use the mongo container defined in
#   docker-compose.dev.yml (hostname "mongo", root/devpassword credentials).
# Leave as-is for local development unless you need to connect to a different
# MongoDB instance.
#
# Production / Azure VM: replace with your Atlas connection string, e.g.:
#   MONGO_CONNECTION_STRING=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_CONNECTION_STRING=mongodb://root:devpassword@mongo:27017/?authSource=admin
MONGO_DATABASE_NAME=NinetyNine

# ─── Container image (production deploy) ──────────────────────────────────────
# Used by docker-compose.yml (prod) only; not needed for local dev.
# GitHub Actions sets IMAGE_TAG to the commit SHA at deploy time.
# GHCR_REPO should be the GitHub repository in "owner/repo" format, e.g.:
#   GHCR_REPO=myuser/ninetynine
GHCR_REPO=owner/repo
IMAGE_TAG=latest
