# Enforce LF line endings for all text files on commit, regardless of
# the developer's OS or editor. Prevents symmetric CRLF↔LF diffs that
# bury real changes in whitespace churn.
#
# Historical note: the working tree picked up CRLF on 21 files during
# the Sprint 6–10 work cycle (likely from a Windows-tooled edit while
# the repo was briefly accessed under WSL2). HEAD remained LF; the
# divergence was reverted on 2026-04-19 and this file added to prevent
# recurrence. See docs/defects.md if a related issue is opened later.

* text=auto eol=lf

# Source
*.cs         text eol=lf diff=csharp
*.csproj     text eol=lf
*.sln        text eol=lf
*.razor      text eol=lf
*.css        text eol=lf
*.js         text eol=lf
*.ts         text eol=lf
*.json       text eol=lf
*.xml        text eol=lf
*.axaml      text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.md         text eol=lf
*.sh         text eol=lf
*.ps1        text eol=crlf
*.bat        text eol=crlf
*.cmd        text eol=crlf
Dockerfile   text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf

# Binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.pdf        binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.eot        binary
