<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="NinetyNine.Presentation.Controls.ConfettiControl"
             IsHitTestVisible="False">

    <Grid>
        <!-- Confetti Canvas -->
        <Canvas Name="ConfettiCanvas"
                Background="Transparent"
                ClipToBounds="False"/>

        <!-- Celebration Message Overlay -->
        <Border Name="MessageOverlay"
                IsVisible="False"
                Background="#CC000000"
                CornerRadius="16"
                Padding="48,24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BoxShadow="0 0 40 10 #80FFD700">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Name="CelebrationTitle"
                           Text="LEGENDARY!"
                           FontSize="48"
                           FontWeight="Bold"
                           Foreground="#FFD700"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <TextBlock Name="CelebrationSubtitle"
                           Text="PERFECT 99!"
                           FontSize="32"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
