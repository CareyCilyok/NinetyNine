<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:NinetyNine.Presentation.ViewModels"
             xmlns:controls="using:NinetyNine.Presentation.Controls"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="NinetyNine.Presentation.Pages.GamePage"
             Background="{DynamicResource BackgroundDeepBrush}">

   <UserControl.DataContext>
      <vm:GamePageViewModel/>
   </UserControl.DataContext>

   <Grid Margin="16">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Game Header -->
      <Border Grid.Row="0"
              Background="{DynamicResource BackgroundMediumBrush}"
              BorderBrush="{DynamicResource NeonBlueBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource RadiusMD}"
              Padding="16"
              Margin="0,0,0,16"
              BoxShadow="0 0 20 3 #3300D4FF">
         <StackPanel>
            <TextBlock Text="Ninety-Nine Pool"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{DynamicResource NeonBlueBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding GameStatus}"
                       FontSize="16"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
         </StackPanel>
      </Border>

      <!-- New Game Controls -->
      <Border Grid.Row="1"
              Background="{DynamicResource BackgroundMediumBrush}"
              BorderBrush="{DynamicResource BackgroundSurfaceBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource RadiusMD}"
              Padding="16"
              Margin="0,0,0,16"
              IsVisible="{Binding !IsGameInProgress}">
         <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="8">
               <TextBlock Text="Player:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
               <TextBox Text="{Binding PlayerName}" Width="120"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
               <TextBlock Text="Venue:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
               <TextBox Text="{Binding VenueName}" Width="120"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
               <TextBlock Text="Table:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
               <ComboBox Width="100">
                  <ComboBoxItem Content="7-Foot"/>
                  <ComboBoxItem Content="9-Foot" IsSelected="True"/>
                  <ComboBoxItem Content="10-Foot"/>
               </ComboBox>
            </StackPanel>

            <Button Command="{Binding NewGameCommand}"
                    Content="New Game"
                    Classes="neon-green"
                    Padding="16,8"
                    FontWeight="Bold"/>
         </StackPanel>
      </Border>

      <!-- Frame Controls Display -->
      <Border Grid.Row="2"
              Background="{DynamicResource BackgroundMediumBrush}"
              BorderBrush="{DynamicResource BackgroundSurfaceBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource RadiusMD}"
              Padding="16"
              Margin="0,0,0,16">
         <StackPanel>
            <TextBlock Text="Game Frames"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

            <!-- Frame Controls Container -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
               <ItemsControl ItemsSource="{Binding FrameViewModels}">
                  <ItemsControl.ItemsPanel>
                     <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                     </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                     <DataTemplate>
                        <controls:FrameControl DataContext="{Binding}"/>
                     </DataTemplate>
                  </ItemsControl.ItemTemplate>
               </ItemsControl>
            </ScrollViewer>
         </StackPanel>
      </Border>

      <!-- Current Frame Scoring Area -->
      <Border Grid.Row="3"
              Background="{DynamicResource BackgroundMediumBrush}"
              BorderBrush="{DynamicResource NeonBlueBrush}"
              BorderThickness="2"
              CornerRadius="{DynamicResource RadiusMD}"
              Padding="20"
              BoxShadow="0 0 20 3 #3300D4FF"
              IsVisible="{Binding IsGameInProgress}">
         <StackPanel>
            <TextBlock Text="{Binding CurrentFrameNumber, StringFormat='Frame {0} of 9'}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource NeonBlueBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Scoring Instructions -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
               <TextBlock TextWrapping="Wrap"
                          HorizontalAlignment="Center"
                          Foreground="{DynamicResource TextSecondaryBrush}">
                  <TextBlock.Text>
                     <MultiBinding StringFormat="Use the + and - buttons in Frame {0} above to set your Break Bonus (0-1) and Ball Count (0-10).">
                        <Binding Path="CurrentFrameNumber"/>
                     </MultiBinding>
                  </TextBlock.Text>
               </TextBlock>
               <TextBlock Text="Maximum 11 points per frame. The 9-ball counts as 2 points."
                          HorizontalAlignment="Center"
                          Foreground="{DynamicResource TextMutedBrush}"
                          TextWrapping="Wrap"
                          Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Frame Action Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="16">
               <Button Command="{Binding CompleteFrameCommand}"
                       Content="Complete Frame"
                       Classes="neon-green"
                       Padding="20,10"
                       FontWeight="Bold"/>
               <Button Command="{Binding ResetFrameCommand}"
                       Content="Reset Frame"
                       Classes="neon-gold"
                       Padding="20,10"/>
               <Button Command="{Binding CompleteGameCommand}"
                       Content="End Game"
                       Classes="neon-red"
                       Padding="20,10"/>
            </StackPanel>
         </StackPanel>
      </Border>

      <!-- Game Completed Display -->
      <Border Grid.Row="3"
              Background="{DynamicResource BackgroundMediumBrush}"
              BorderBrush="{DynamicResource NeonGoldBrush}"
              BorderThickness="3"
              CornerRadius="{DynamicResource RadiusMD}"
              Padding="32"
              BoxShadow="0 0 30 8 #33FFD700"
              IsVisible="{Binding IsGameCompleted}">
         <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="{Binding GameStatus}"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource NeonGoldBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>
            <TextBlock Text="{Binding TotalScore, StringFormat='Final Score: {0} / 99'}"
                       FontSize="20"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>
            <Button Command="{Binding NewGameCommand}"
                    Content="Play Again"
                    Classes="neon-green"
                    Padding="24,12"
                    FontWeight="Bold"
                    FontSize="16"
                    HorizontalAlignment="Center"/>
         </StackPanel>
      </Border>

      <!-- Footer -->
      <Border Grid.Row="4"
              Background="{DynamicResource BackgroundMediumBrush}"
              BorderBrush="{DynamicResource BackgroundSurfaceBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource RadiusMD}"
              Padding="16"
              Margin="0,16,0,0">
         <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24">
            <StackPanel Orientation="Horizontal">
               <TextBlock Text="Total Score: " FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
               <TextBlock Text="{Binding TotalScore}" FontWeight="Bold" Foreground="{DynamicResource NeonBlueBrush}" FontSize="18"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
               <TextBlock Text="Frame: " FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
               <TextBlock Text="{Binding CurrentFrameNumber}" FontWeight="Bold" Foreground="{DynamicResource NeonBlueBrush}"/>
               <TextBlock Text=" / 9" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
         </StackPanel>
      </Border>

      <!-- Confetti Overlay (shows when ShowConfetti is true) -->
      <controls:ConfettiControl Grid.RowSpan="5"
                                IsVisible="{Binding ShowConfetti}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
   </Grid>
</UserControl>
