<Dropdown TItem="string" OnSelected="@OnSelected">
    <InitialTip>Choose a state</InitialTip>
    <ChildContent>
        @foreach (var state in states)
        {
            <DropdownItem Item=@state>
                @state
            </DropdownItem>
        }
        </ChildContent>
</Dropdown>

