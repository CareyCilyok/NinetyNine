@inherits LayoutComponentBase

@*
    MainLayout — application shell.
    -----------------------------------------------------------------
    Static SSR by design: a Blazor layout cannot opt into an
    interactive render mode because @Body is a non-serializable
    RenderFragment. Interactivity (hamburger toggle, NavMenu close
    callback, UserMenu dropdown, badge counts) lives in the
    <Sidebar /> child component, which IS InteractiveServer.
*@

<div class="nn-layout">

    @* Skip-to-main — visually hidden, appears on focus (WCAG 2.4.1). *@
    <a href="#nn-main-content" class="nn-layout__skip-link">
        Skip to main content
    </a>

    <Sidebar />

    <main id="nn-main-content" class="nn-layout__main" role="main">
        <div class="nn-layout__content">
            @Body
        </div>

        <footer class="nn-layout__footer">
            <small>
                NinetyNine &mdash; Pool scorekeeper. &copy; @DateTime.UtcNow.Year
            </small>
        </footer>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <a class="dismiss" role="button" tabindex="0" aria-label="Dismiss error">&#x2715;</a>
</div>
