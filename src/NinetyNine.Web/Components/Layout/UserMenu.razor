@*
    UserMenu — sidebar-footer user block.
    -----------------------------------------------------------------
    Two states:
      * NotAuthorized: a compact "Sign in" primary button + a muted
        "Create account" link, sized to fit inside the sidebar footer.
      * Authorized: an avatar + display name trigger that toggles a
        dropdown popping UP above the block (because it lives at the
        bottom of the sidebar). Menu items: View profile, Edit profile,
        Settings, Sign out (the last is a form POST with antiforgery).

    Dropdown state is a single bool. Click outside closes it via a
    full-viewport "catcher" element. Escape key closes it via @onkeydown.
    No JS interop.
*@

<AuthorizeView>
    <Authorized Context="authContext">
        @{
            var displayName = authContext.User.Identity?.Name ?? "Player";
            var avatarUrl = authContext.User.FindFirst(ClaimNames.AvatarUrl)?.Value;
        }

        @if (_dropdownOpen)
        {
            @* Transparent full-viewport backdrop catches outside clicks. *@
            <div class="nn-user__backdrop"
                 role="presentation"
                 @onclick="Close"></div>
        }

        <div class="nn-user @(_dropdownOpen ? "nn-user--open" : string.Empty)"
             @onkeydown="HandleKeyDown">

            @if (_dropdownOpen)
            {
                <div class="nn-user__menu"
                     role="menu"
                     aria-label="User menu">
                    <a class="nn-user__item"
                       role="menuitem"
                       href="players/me"
                       @onclick="Close">
                        View profile
                    </a>
                    <a class="nn-user__item"
                       role="menuitem"
                       href="players/me/edit"
                       @onclick="Close">
                        Edit profile
                    </a>
                    <a class="nn-user__item"
                       role="menuitem"
                       href="friends"
                       @onclick="Close">
                        Friends
                        @if (PendingFriendRequestCount > 0)
                        {
                            <span class="nn-user__item-badge"
                                  aria-label="@($"{PendingFriendRequestCount} pending")">
                                @PendingFriendRequestCount
                            </span>
                        }
                    </a>
                    <a class="nn-user__item"
                       role="menuitem"
                       href="settings"
                       @onclick="Close">
                        Settings
                    </a>
                    <div class="nn-user__divider" role="separator"></div>
                    <form method="post" action="logout" class="nn-user__signout-form">
                        <AntiforgeryToken />
                        <button type="submit"
                                role="menuitem"
                                class="nn-user__item nn-user__item--danger">
                            Sign out
                        </button>
                    </form>
                </div>
            }

            <button type="button"
                    class="nn-user__trigger"
                    aria-haspopup="menu"
                    aria-expanded="@(_dropdownOpen ? "true" : "false")"
                    aria-label="User menu for @displayName"
                    @onclick="Toggle"
                    @onclick:stopPropagation="true">

                <AvatarImage AvatarUrl="@avatarUrl"
                             DisplayName="@displayName"
                             SizePx="40" />

                <span class="nn-user__name">@displayName</span>

                <img src="@(_dropdownOpen
                            ? "icons/phosphor/regular/caret-down.svg"
                            : "icons/phosphor/regular/caret-up.svg")"
                     alt=""
                     role="presentation"
                     class="nn-user__caret" />
            </button>
        </div>
    </Authorized>

    <NotAuthorized>
        <div class="nn-user__signin">
            <a href="login" class="btn btn-primary nn-user__signin-btn">
                Sign in
            </a>
            <a href="register" class="nn-user__signin-link">
                Create account
            </a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _dropdownOpen;

    /// <summary>
    /// Cascaded from <c>MainLayout</c>. Matches <c>NavMenu.PendingFriendRequestCount</c>
    /// so both the sidebar nav item and the user-menu item show the same
    /// badge count without duplicating the Mongo round trip.
    /// </summary>
    [CascadingParameter(Name = "PendingFriendRequestCount")]
    public int PendingFriendRequestCount { get; set; }

    private void Toggle() => _dropdownOpen = !_dropdownOpen;

    private void Close() => _dropdownOpen = false;

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && _dropdownOpen)
        {
            _dropdownOpen = false;
        }
    }
}
