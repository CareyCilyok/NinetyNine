@page "/communities/{CommunityId:guid}"
@attribute [Authorize]
@inject ICommunityService CommunityService
@inject ICommunityJoinRequestRepository JoinRequestRepository
@inject IPlayerRepository PlayerRepository
@inject IVenueService VenueService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject ILogger<Detail> Logger
@using System.ComponentModel.DataAnnotations

<PageTitle>
    @(_community is not null ? $"{_community.Name} — NinetyNine" : "Community — NinetyNine")
</PageTitle>

<div class="nn-page nn-community-detail">
    @if (_notFound)
    {
        <div class="nn-community-detail__not-found">
            <h1 class="nn-community-detail__not-found-title">Community not found</h1>
            <p class="nn-community-detail__not-found-body">
                This community does not exist, or it's private and you are not a member.
            </p>
            <a href="/communities" class="btn btn-primary">Back to communities</a>
        </div>
    }
    else if (_community is null)
    {
        <div class="nn-community-detail__loading" aria-live="polite" aria-busy="true">
            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            Loading&hellip;
        </div>
    }
    else
    {
        <div class="nn-community-detail__inner">
            @if (!string.IsNullOrEmpty(_flashSuccess))
            {
                <div class="alert alert-success nn-community-detail__flash" role="status">
                    @_flashSuccess
                </div>
            }
            @if (!string.IsNullOrEmpty(_flashError))
            {
                <div class="alert alert-danger nn-community-detail__flash" role="alert">
                    @_flashError
                </div>
            }

            <header class="nn-community-detail__header">
                <div class="nn-community-detail__header-info">
                    <div class="nn-community-detail__title-row">
                        <h1 class="nn-community-detail__title">@_community.Name</h1>
                        <span class="nn-community-detail__pill @(_community.Visibility == CommunityVisibility.Private
                            ? "nn-community-detail__pill--private"
                            : "nn-community-detail__pill--public")">
                            @(_community.Visibility == CommunityVisibility.Private ? "Private" : "Public")
                        </span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_community.Description))
                    {
                        <p class="nn-community-detail__description">@_community.Description</p>
                    }
                    <p class="nn-community-detail__meta">
                        @_memberCount @(_memberCount == 1 ? "member" : "members")
                    </p>
                </div>

                <div class="nn-community-detail__actions">
                    @if (_isOwner)
                    {
                        <a href="/communities/@_community.CommunityId/settings"
                           class="btn btn-ghost btn-sm">Settings</a>
                    }
                    else if (_isMember)
                    {
                        <EditForm Model="_leaveModel" method="post"
                                  OnValidSubmit="HandleLeaveAsync"
                                  FormName="leave-community">
                            <button type="submit" class="btn btn-ghost btn-sm">Leave community</button>
                        </EditForm>
                    }
                    else if (_community.Visibility == CommunityVisibility.Public)
                    {
                        <EditForm Model="_joinModel" method="post"
                                  OnValidSubmit="HandleJoinAsync"
                                  FormName="join-community">
                            <button type="submit" class="btn btn-primary">Join community</button>
                        </EditForm>
                    }
                    else
                    {
                        @* Private community the viewer is not a member of — but
                           the route guard already 404s these, so this branch is
                           only reachable for private communities visible because
                           the viewer is in an earlier state we missed. *@
                        <span class="nn-community-detail__private-note">
                            Invitation only.
                        </span>
                    }
                </div>
            </header>

            @* ── Owner/Admin: pending join requests ────────────────── *@
            @if (_isOwnerOrAdmin && _pendingJoinRequests.Count > 0)
            {
                <section class="nn-community-detail__section"
                         aria-label="Pending join requests">
                    <h2 class="nn-community-detail__section-title">Pending join requests</h2>
                    <ul class="nn-community-detail__members" role="list">
                        @foreach (var req in _pendingJoinRequests)
                        {
                            var requester = _joinRequesters.GetValueOrDefault(req.PlayerId);
                            <li class="nn-community-detail__member-row" role="listitem">
                                <PlayerBadge PlayerId="@req.PlayerId"
                                             DisplayName="@(requester?.DisplayName ?? "Unknown")"
                                             AvatarUrl="@(requester?.Avatar is not null ? $"/api/avatars/{req.PlayerId}" : null)"
                                             AvatarSizePx="40" />
                                <div class="nn-community-detail__member-actions">
                                    <EditForm Model="_requestIdModel" method="post"
                                              OnValidSubmit="HandleApproveJoinAsync"
                                              FormName="@($"approve-join-{req.RequestId}")">
                                        <input type="hidden"
                                               name="_requestIdModel.RequestId"
                                               value="@req.RequestId" />
                                        <button type="submit" class="btn btn-primary btn-sm">
                                            Approve
                                        </button>
                                    </EditForm>
                                    <EditForm Model="_requestIdModel" method="post"
                                              OnValidSubmit="HandleDenyJoinAsync"
                                              FormName="@($"deny-join-{req.RequestId}")">
                                        <input type="hidden"
                                               name="_requestIdModel.RequestId"
                                               value="@req.RequestId" />
                                        <button type="submit" class="btn btn-ghost btn-sm">
                                            Deny
                                        </button>
                                    </EditForm>
                                </div>
                            </li>
                        }
                    </ul>
                </section>
            }

            @* ── Members section ──────────────────────────────────── *@
            <section class="nn-community-detail__section" aria-label="Members">
                <h2 class="nn-community-detail__section-title">Members</h2>

                @if (_members.Count == 0)
                {
                    <p class="nn-community-detail__section-empty">No members yet.</p>
                }
                else
                {
                    <ul class="nn-community-detail__members" role="list">
                        @foreach (var m in _members)
                        {
                            <li class="nn-community-detail__member-row" role="listitem">
                                <PlayerBadge PlayerId="@m.PlayerId"
                                             DisplayName="@m.DisplayName"
                                             AvatarUrl="@m.AvatarUrl"
                                             AvatarSizePx="40" />
                                <span class="nn-community-detail__member-role nn-community-detail__member-role--@m.Role.ToString().ToLowerInvariant()">
                                    @(m.Role == CommunityRole.Owner ? "Owner"
                                      : m.Role == CommunityRole.Admin ? "Admin"
                                      : "Member")
                                </span>
                                @if (_isOwner && m.PlayerId != _viewerId && m.Role != CommunityRole.Owner)
                                {
                                    <div class="nn-community-detail__member-actions">
                                        @if (m.Role == CommunityRole.Member)
                                        {
                                            <EditForm Model="_roleChangeModel" method="post"
                                                      OnValidSubmit="HandleMakeAdminAsync"
                                                      FormName="@($"make-admin-{m.PlayerId}")">
                                                <input type="hidden"
                                                       name="_roleChangeModel.TargetPlayerId"
                                                       value="@m.PlayerId" />
                                                <button type="submit" class="btn btn-ghost btn-sm">
                                                    Make Admin
                                                </button>
                                            </EditForm>
                                        }
                                        else if (m.Role == CommunityRole.Admin)
                                        {
                                            <EditForm Model="_roleChangeModel" method="post"
                                                      OnValidSubmit="HandleRemoveAdminAsync"
                                                      FormName="@($"remove-admin-{m.PlayerId}")">
                                                <input type="hidden"
                                                       name="_roleChangeModel.TargetPlayerId"
                                                       value="@m.PlayerId" />
                                                <button type="submit" class="btn btn-ghost btn-sm">
                                                    Remove Admin
                                                </button>
                                            </EditForm>
                                        }
                                    </div>
                                }
                            </li>
                        }
                    </ul>
                }
            </section>

            @* ── Owner/Admin: invite a player by display name ────── *@
            @if (_isOwnerOrAdmin)
            {
                <section class="nn-community-detail__section"
                         aria-label="Invite a player">
                    <h2 class="nn-community-detail__section-title">Invite a player</h2>
                    <EditForm Model="_inviteModel" method="post"
                              OnValidSubmit="HandleInviteAsync"
                              FormName="invite-to-community">
                        <div class="nn-community-detail__invite-row">
                            <InputText id="invite-display-name"
                                       class="form-control"
                                       @bind-Value="_inviteModel.DisplayName"
                                       placeholder="Display name"
                                       autocomplete="off"
                                       aria-label="Player display name" />
                            <button type="submit" class="btn btn-primary">Send invite</button>
                        </div>
                        <p class="nn-community-detail__section-empty">
                            Only display names are searched. The recipient will see the invitation in their /friends Requests tab.
                        </p>
                    </EditForm>
                </section>
            }

            @* ── Pending ownership transfer notice (for the target) ──── *@
            @if (_pendingTransfer is not null && _pendingTransfer.ToPlayerId == _viewerId)
            {
                <div class="alert alert-warning nn-community-detail__transfer-notice" role="alert">
                    <p>
                        @(_transferFromName ?? "The current owner") wants to hand you ownership
                        of @_community.Name.
                    </p>
                    <div class="nn-community-detail__transfer-actions">
                        <EditForm Model="_transferResponseModel" method="post"
                                  OnValidSubmit="HandleAcceptTransferAsync"
                                  FormName="accept-transfer">
                            <input type="hidden"
                                   name="_transferResponseModel.TransferId"
                                   value="@_pendingTransfer.TransferId" />
                            <button type="submit" class="btn btn-primary btn-sm">Accept ownership</button>
                        </EditForm>
                        <EditForm Model="_transferResponseModel" method="post"
                                  OnValidSubmit="HandleDeclineTransferAsync"
                                  FormName="decline-transfer">
                            <input type="hidden"
                                   name="_transferResponseModel.TransferId"
                                   value="@_pendingTransfer.TransferId" />
                            <button type="submit" class="btn btn-ghost btn-sm">No thanks</button>
                        </EditForm>
                    </div>
                </div>
            }

            @* ── Owner: transfer ownership ───────────────────────────── *@
            @if (_isOwner)
            {
                <section class="nn-community-detail__section"
                         aria-label="Transfer ownership">
                    <h2 class="nn-community-detail__section-title">Transfer ownership</h2>
                    @if (_pendingTransfer is not null)
                    {
                        <p class="nn-community-detail__section-empty">
                            Ownership transfer pending — waiting for
                            @(_transferToName ?? "the target") to respond.
                            Expires @_pendingTransfer.ExpiresAt.ToString("MMM d, yyyy").
                        </p>
                    }
                    else
                    {
                        <EditForm Model="_transferModel" method="post"
                                  OnValidSubmit="HandleInitiateTransferAsync"
                                  FormName="initiate-transfer">
                            <div class="nn-community-detail__invite-row">
                                <InputText id="transfer-display-name"
                                           class="form-control"
                                           @bind-Value="_transferModel.DisplayName"
                                           placeholder="Display name of new owner"
                                           autocomplete="off"
                                           aria-label="New owner display name" />
                                <button type="submit" class="btn btn-primary">Send request</button>
                            </div>
                            <p class="nn-community-detail__section-empty">
                                The member must accept within 7 days.
                            </p>
                        </EditForm>
                    }
                </section>
            }

            @* ── Affiliated venues ────────────────────────────────── *@
            <section class="nn-community-detail__section" aria-label="Affiliated venues">
                <h2 class="nn-community-detail__section-title">Venues</h2>
                @if (_affiliatedVenues.Count == 0)
                {
                    <p class="nn-community-detail__section-empty">
                        No venues are affiliated with this community yet.
                    </p>
                }
                else
                {
                    <ul class="nn-community-detail__members" role="list">
                        @foreach (var v in _affiliatedVenues)
                        {
                            <li class="nn-community-detail__member-row" role="listitem">
                                <a href="/venues/@v.VenueId/edit" class="nn-community-detail__venue-link">
                                    <span>@v.Name</span>
                                    @if (!string.IsNullOrWhiteSpace(v.Address))
                                    {
                                        <span class="nn-community-detail__venue-address">@v.Address</span>
                                    }
                                </a>
                            </li>
                        }
                    </ul>
                }
            </section>
        </div>
    }
</div>

@code {
    [Parameter] public Guid CommunityId { get; set; }

    [SupplyParameterFromQuery(Name = "flash")]
    public string? Flash { get; set; }

    [SupplyParameterFromForm]
    private EmptyModel _joinModel { get; set; } = new();

    [SupplyParameterFromForm]
    private EmptyModel _leaveModel { get; set; } = new();

    [SupplyParameterFromForm(FormName = "invite-to-community")]
    private InviteModel _inviteModel { get; set; } = new();

    [SupplyParameterFromForm]
    private RequestIdModel _requestIdModel { get; set; } = new();

    [SupplyParameterFromForm]
    private RoleChangeModel _roleChangeModel { get; set; } = new();

    [SupplyParameterFromForm(FormName = "initiate-transfer")]
    private TransferModel _transferModel { get; set; } = new();

    [SupplyParameterFromForm]
    private TransferResponseModel _transferResponseModel { get; set; } = new();

    private Guid? _viewerId;
    private Community? _community;
    private bool _notFound;
    private bool _isMember;
    private bool _isOwner;
    private bool _isOwnerOrAdmin;
    private OwnershipTransfer? _pendingTransfer;
    private string? _transferFromName;
    private string? _transferToName;
    private List<Venue> _affiliatedVenues = [];
    private List<CommunityMemberView> _members = [];
    private long _memberCount;
    private List<CommunityJoinRequest> _pendingJoinRequests = [];
    private Dictionary<Guid, Player> _joinRequesters = new();
    private string _flashSuccess = "";
    private string _flashError = "";

    protected override void OnInitialized()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        var claim = user?.FindFirst(ClaimNames.PlayerId)?.Value;
        if (Guid.TryParse(claim, out var id))
            _viewerId = id;

        _flashSuccess = Flash switch
        {
            "created" => "Community created.",
            "joined" => "You joined the community.",
            "invited" => "Invitation sent.",
            "approved" => "Join request approved.",
            "denied" => "Join request denied.",
            "role-changed" => "Role updated.",
            "transfer-sent" => "Ownership transfer request sent.",
            "transfer-accepted" => "You are now the owner.",
            "transfer-declined" => "Ownership transfer declined.",
            _ => "",
        };
    }

    protected override async Task OnInitializedAsync()
    {
        if (_viewerId is null)
        {
            Navigation.NavigateTo($"/login?ReturnUrl=/communities/{CommunityId}", forceLoad: true);
            return;
        }

        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _community = await CommunityService.GetForViewerAsync(CommunityId, _viewerId);
        if (_community is null)
        {
            _notFound = true;
            return;
        }

        _isMember = await CommunityService.IsMemberAsync(CommunityId, _viewerId!.Value);
        _isOwner = _community.OwnerPlayerId == _viewerId;
        _members = (await CommunityService.ListMembersAsync(CommunityId, _viewerId)).ToList();
        _memberCount = _members.Count;

        // An admin is any member with Role == Admin (checked from the
        // already-fetched member list to avoid a second roundtrip).
        _isOwnerOrAdmin = _isOwner
            || _members.Any(m => m.PlayerId == _viewerId && m.Role == CommunityRole.Admin);

        // Owner/Admin: load pending join requests + preload requester profiles.
        if (_isOwnerOrAdmin)
        {
            _pendingJoinRequests =
                (await JoinRequestRepository.ListPendingByCommunityAsync(CommunityId)).ToList();
            _joinRequesters = new Dictionary<Guid, Player>();
            foreach (var req in _pendingJoinRequests)
            {
                var p = await PlayerRepository.GetByIdAsync(req.PlayerId);
                if (p is not null) _joinRequesters[req.PlayerId] = p;
            }
        }

        // Load pending ownership transfer (visible to owner + target).
        _pendingTransfer = await CommunityService.GetPendingTransferAsync(CommunityId);
        if (_pendingTransfer is not null)
        {
            var from = await PlayerRepository.GetByIdAsync(_pendingTransfer.FromPlayerId);
            _transferFromName = from?.DisplayName;
            var to = await PlayerRepository.GetByIdAsync(_pendingTransfer.ToPlayerId);
            _transferToName = to?.DisplayName;
        }

        // Load affiliated venues.
        var allVenues = await VenueService.ListAsync(includePrivate: false);
        _affiliatedVenues = allVenues
            .Where(v => v.CommunityId == CommunityId)
            .OrderBy(v => v.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private async Task HandleInviteAsync()
    {
        if (_viewerId is null || string.IsNullOrWhiteSpace(_inviteModel.DisplayName))
        {
            _flashError = "Enter a display name to invite.";
            return;
        }

        var target = await PlayerRepository.GetByDisplayNameAsync(_inviteModel.DisplayName.Trim());
        if (target is null)
        {
            _flashError = "No player with that display name.";
            await ReloadAsync();
            return;
        }

        var result = await CommunityService.InviteAsync(
            CommunityId, target.PlayerId, _viewerId.Value);
        if (!result.Success)
        {
            _flashError = result.ErrorMessage ?? "Could not send the invitation.";
            await ReloadAsync();
            return;
        }

        Navigation.NavigateTo($"/communities/{CommunityId}?flash=invited");
    }

    private async Task HandleApproveJoinAsync()
    {
        if (_viewerId is null || _requestIdModel.RequestId == Guid.Empty) return;

        var result = await CommunityService.ApproveJoinRequestAsync(
            _requestIdModel.RequestId, _viewerId.Value);
        if (!result.Success)
        {
            _flashError = result.ErrorMessage ?? "Could not approve the request.";
            await ReloadAsync();
            return;
        }

        Navigation.NavigateTo($"/communities/{CommunityId}?flash=approved");
    }

    private async Task HandleDenyJoinAsync()
    {
        if (_viewerId is null || _requestIdModel.RequestId == Guid.Empty) return;

        var result = await CommunityService.DenyJoinRequestAsync(
            _requestIdModel.RequestId, _viewerId.Value);
        if (!result.Success)
        {
            _flashError = result.ErrorMessage ?? "Could not deny the request.";
            await ReloadAsync();
            return;
        }

        Navigation.NavigateTo($"/communities/{CommunityId}?flash=denied");
    }

    private sealed class InviteModel
    {
        public string? DisplayName { get; set; }
    }

    private sealed class RequestIdModel
    {
        public Guid RequestId { get; set; }
    }

    private async Task HandleJoinAsync()
    {
        if (_viewerId is null) return;

        var result = await CommunityService.JoinPublicAsync(CommunityId, _viewerId.Value);
        if (!result.Success)
        {
            _flashError = result.ErrorMessage ?? "Could not join the community.";
            await ReloadAsync();
            return;
        }

        Navigation.NavigateTo($"/communities/{CommunityId}?flash=joined");
    }

    private async Task HandleLeaveAsync()
    {
        if (_viewerId is null) return;

        var result = await CommunityService.LeaveAsync(CommunityId, _viewerId.Value);
        if (!result.Success)
        {
            _flashError = result.ErrorMessage ?? "Could not leave the community.";
            await ReloadAsync();
            return;
        }

        Navigation.NavigateTo("/communities?flash=left");
    }

    private sealed class EmptyModel { }

    private sealed class RoleChangeModel
    {
        public Guid TargetPlayerId { get; set; }
    }

    private async Task HandleMakeAdminAsync()
    {
        if (_viewerId is null || _roleChangeModel.TargetPlayerId == Guid.Empty) return;

        var result = await CommunityService.SetMemberRoleAsync(
            CommunityId, _roleChangeModel.TargetPlayerId, CommunityRole.Admin, _viewerId.Value);
        if (!result.Success)
        {
            _flashError = result.ErrorMessage ?? "Could not change role.";
            await ReloadAsync();
            return;
        }

        Navigation.NavigateTo($"/communities/{CommunityId}?flash=role-changed");
    }

    private async Task HandleRemoveAdminAsync()
    {
        if (_viewerId is null || _roleChangeModel.TargetPlayerId == Guid.Empty) return;

        var result = await CommunityService.SetMemberRoleAsync(
            CommunityId, _roleChangeModel.TargetPlayerId, CommunityRole.Member, _viewerId.Value);
        if (!result.Success)
        {
            _flashError = result.ErrorMessage ?? "Could not change role.";
            await ReloadAsync();
            return;
        }

        Navigation.NavigateTo($"/communities/{CommunityId}?flash=role-changed");
    }

    private sealed class TransferModel
    {
        public string? DisplayName { get; set; }
    }

    private sealed class TransferResponseModel
    {
        public Guid TransferId { get; set; }
    }

    private async Task HandleInitiateTransferAsync()
    {
        if (_viewerId is null || string.IsNullOrWhiteSpace(_transferModel.DisplayName))
        {
            _flashError = "Enter the display name of the new owner.";
            return;
        }

        var target = await PlayerRepository.GetByDisplayNameAsync(_transferModel.DisplayName.Trim());
        if (target is null)
        {
            _flashError = "No player with that display name.";
            await ReloadAsync();
            return;
        }

        var result = await CommunityService.TransferOwnershipAsync(
            CommunityId, target.PlayerId, _viewerId.Value);
        if (!result.Success)
        {
            _flashError = result.ErrorMessage ?? "Could not initiate the transfer.";
            await ReloadAsync();
            return;
        }

        Navigation.NavigateTo($"/communities/{CommunityId}?flash=transfer-sent");
    }

    private async Task HandleAcceptTransferAsync()
    {
        if (_viewerId is null || _transferResponseModel.TransferId == Guid.Empty) return;

        var result = await CommunityService.RespondToTransferAsync(
            _transferResponseModel.TransferId, _viewerId.Value, accept: true);
        if (!result.Success)
        {
            _flashError = result.ErrorMessage ?? "Could not accept the transfer.";
            await ReloadAsync();
            return;
        }

        Navigation.NavigateTo($"/communities/{CommunityId}?flash=transfer-accepted");
    }

    private async Task HandleDeclineTransferAsync()
    {
        if (_viewerId is null || _transferResponseModel.TransferId == Guid.Empty) return;

        var result = await CommunityService.RespondToTransferAsync(
            _transferResponseModel.TransferId, _viewerId.Value, accept: false);
        if (!result.Success)
        {
            _flashError = result.ErrorMessage ?? "Could not decline the transfer.";
            await ReloadAsync();
            return;
        }

        Navigation.NavigateTo($"/communities/{CommunityId}?flash=transfer-declined");
    }
}
