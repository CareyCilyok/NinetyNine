@page "/forgot-password"
@using System.ComponentModel.DataAnnotations
@using NinetyNine.Services.Auth
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILogger<ForgotPassword> Logger

<PageTitle>Forgot password &mdash; NinetyNine</PageTitle>

<div class="nn-page nn-auth-page">
    <div class="nn-auth-card">
        <div class="nn-auth-card__wordmark" aria-hidden="true">NinetyNine</div>
        <h1 class="nn-auth-card__title">Reset your password</h1>
        <p class="nn-auth-card__subtitle">
            Enter your email address and we will send you a reset link if an account exists.
        </p>

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="alert alert-success" role="alert">@_successMessage</div>
        }

        @if (!_submitted)
        {
            <EditForm Model="_model" method="post" OnValidSubmit="HandleSubmitAsync" FormName="forgot-password">
                @* AntiforgeryToken auto-injected by Blazor SSR form handler.
                   See docs/defects.md DEF-003. *@
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label class="form-label" for="email">Email address</label>
                    <InputText id="email" type="email"
                               class="form-control"
                               @bind-Value="_model.Email"
                               autocomplete="email" required />
                    <ValidationMessage For="() => _model.Email" />
                </div>

                <button type="submit" class="btn btn-primary w-100" disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <span>Sending&hellip;</span>
                    }
                    else
                    {
                        <span>Send reset link</span>
                    }
                </button>
            </EditForm>
        }

        <p class="nn-auth-card__aside">
            <a href="/login">Back to sign in</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromForm(FormName = "forgot-password")]
    private ForgotPasswordModel _model { get; set; } = new();

    private string _successMessage = "";
    private bool _isSubmitting;
    private bool _submitted;

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;

        try
        {
            var resetUrlBase = new Uri(Navigation.BaseUri).GetLeftPart(UriPartial.Authority);
            await AuthService.ForgotPasswordAsync(_model.Email, resetUrlBase);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error during forgot-password request.");
        }
        finally
        {
            // Always show the generic message regardless of outcome — no enumeration.
            _submitted = true;
            _isSubmitting = false;
            _successMessage = "If an account with that email exists, a password reset link has been sent. Check your inbox.";
        }
    }

    private sealed class ForgotPasswordModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";
    }
}
