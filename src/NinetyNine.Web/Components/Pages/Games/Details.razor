@page "/games/{GameId:guid}"
@attribute [Authorize]
@inject IGameService GameService
@inject IVenueService VenueService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject ILogger<Details> Logger

<PageTitle>
    @(_game is not null
        ? $"Game \u2014 {_game.WhenPlayed.ToLocalTime():MMMM d, yyyy}"
        : "Game Details") &mdash; NinetyNine
</PageTitle>

<div class="nn-page nn-details-page">

    @if (_loading)
    {
        <div class="nn-details-page__loading" aria-live="polite" aria-busy="true">
            <span class="spinner-border spinner-border-sm me-2"
                  role="status"
                  aria-hidden="true"></span>
            Loading&hellip;
        </div>
    }
    else if (_game is null)
    {
        <div class="nn-details-page__not-found">
            <h1 class="nn-details-page__not-found-title">Game not found</h1>
            <p class="nn-details-page__not-found-body">
                This game does not exist or you do not have access to it.
            </p>
            <a href="/games" class="btn btn-outline-secondary">Back to history</a>
        </div>
    }
    else
    {
        @* Header strip *@
        <header class="nn-details-page__header">
            <div class="nn-details-page__meta">
                <h1 class="nn-details-page__title">
                    Game &mdash;
                    <time datetime="@_game.WhenPlayed.ToString("O")">
                        @_game.WhenPlayed.ToLocalTime().ToString("MMMM d, yyyy")
                    </time>
                </h1>
                <div class="nn-details-page__meta-row">
                    @if (!string.IsNullOrWhiteSpace(_venueName))
                    {
                        <span class="nn-details-page__venue">@_venueName</span>
                        <span class="nn-details-page__sep" aria-hidden="true">&middot;</span>
                    }
                    <span class="nn-details-page__table-size">
                        @TableSizeLabel(_game.TableSize)
                    </span>
                    <span class="nn-details-page__sep" aria-hidden="true">&middot;</span>
                    <time class="nn-details-page__when"
                          datetime="@_game.WhenPlayed.ToString("O")"
                          title="@_game.WhenPlayed.ToLocalTime().ToString("f")">
                        @_game.WhenPlayed.ToLocalTime().ToString("MMM d, h:mm tt")
                    </time>
                    <span class="nn-details-page__sep" aria-hidden="true">&middot;</span>
                    <span class="nn-status-pill @StatusPillClass(_game.GameState)">
                        @StatusLabel(_game.GameState)
                    </span>
                </div>
            </div>
            <div class="nn-details-page__score-display" aria-label="Final score">
                <span class="nn-details-page__score-value @(_game.IsPerfectGame ? "nn-details-page__score-value--perfect" : "")">
                    @_game.TotalScore
                </span>
                <span class="nn-details-page__score-max">/ 90</span>
                @if (_game.IsPerfectGame)
                {
                    <div class="nn-details-page__perfect-badge" aria-label="Perfect game">
                        Perfect game!
                    </div>
                }
            </div>
        </header>

        @* Read-only score card *@
        <section class="nn-details-page__scorecard" aria-label="Score card">
            <ScoreCardGrid Game="_game" Mode="ScoreCardMode.View" />
        </section>

        @* Stats card *@
        <section class="nn-details-page__stats" aria-label="Game statistics">
            <h2 class="nn-details-page__stats-title">Statistics</h2>
            <div class="nn-details-page__stats-grid">
                <div class="nn-details-page__stat-card">
                    <div class="nn-details-page__stat-value">
                        @_game.TotalScore<span class="nn-details-page__stat-denominator">/90</span>
                    </div>
                    <div class="nn-details-page__stat-label">Total Score</div>
                </div>
                <div class="nn-details-page__stat-card">
                    <div class="nn-details-page__stat-value">
                        @(_game.AverageScore > 0 ? _game.AverageScore.ToString("F1") : "\u2014")
                    </div>
                    <div class="nn-details-page__stat-label">Avg / Frame</div>
                </div>
                <div class="nn-details-page__stat-card">
                    <div class="nn-details-page__stat-value">
                        @(_game.BestFrame is not null ? _game.BestFrame.FrameScore.ToString() : "\u2014")
                        @if (_game.BestFrame is not null)
                        {
                            <span class="nn-details-page__stat-sub">frame @_game.BestFrame.FrameNumber</span>
                        }
                    </div>
                    <div class="nn-details-page__stat-label">Best Frame</div>
                </div>
                <div class="nn-details-page__stat-card">
                    <div class="nn-details-page__stat-value">@_game.PerfectFrames</div>
                    <div class="nn-details-page__stat-label">Perfect Frames</div>
                </div>
                @if (_game.CompletedAt.HasValue)
                {
                    var duration = _game.CompletedAt.Value - _game.WhenPlayed;
                    <div class="nn-details-page__stat-card">
                        <div class="nn-details-page__stat-value">
                            @FormatDuration(duration)
                        </div>
                        <div class="nn-details-page__stat-label">Duration</div>
                    </div>
                }
            </div>
        </section>

        @* Notes block *@
        @if (!string.IsNullOrWhiteSpace(_game.Notes))
        {
            <section class="nn-details-page__notes" aria-label="Game notes">
                <h2 class="nn-details-page__notes-title">Notes</h2>
                <p class="nn-details-page__notes-body">@_game.Notes</p>
            </section>
        }

        @* Action links *@
        <footer class="nn-details-page__actions">
            <a href="/games" class="btn btn-outline-secondary">Back to history</a>
            <a href="/games/new" class="btn btn-primary">Start new game</a>
        </footer>
    }

</div>

@code {
    [Parameter] public Guid GameId { get; set; }

    private Game? _game;
    private bool _loading = true;
    private string? _venueName;
    private Guid? _playerId;

    protected override void OnInitialized()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        var claim = user?.FindFirst(ClaimNames.PlayerId)?.Value;
        if (Guid.TryParse(claim, out var id))
            _playerId = id;
    }

    protected override async Task OnInitializedAsync()
    {
        if (_playerId is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        var game = await GameService.GetGameAsync(GameId);

        // Ownership guard: don't reveal existence via 403 text
        if (game is null || game.PlayerId != _playerId)
        {
            _game = null;
            _loading = false;
            return;
        }

        // In-progress games belong on the play page
        if (game.IsInProgress)
        {
            Navigation.NavigateTo($"/games/{GameId}/play", forceLoad: false);
            return;
        }

        _game = game;

        // Resolve venue name (best-effort)
        try
        {
            var venue = await VenueService.GetAsync(game.VenueId);
            _venueName = venue?.Name;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex,
                "Could not resolve venue {VenueId} for game {GameId}.", game.VenueId, GameId);
        }

        _loading = false;
    }

    // ── Display helpers ───────────────────────────────────────────────

    private static string TableSizeLabel(TableSize size) => size switch
    {
        TableSize.SixFoot   => "6 ft",
        TableSize.SevenFoot => "7 ft",
        TableSize.NineFoot  => "9 ft",
        TableSize.TenFoot   => "10 ft",
        _                   => size.ToString()
    };

    private static string StatusLabel(GameState state) => state switch
    {
        GameState.Completed  => "Completed",
        GameState.InProgress => "In progress",
        GameState.Paused     => "Paused",
        _                    => "Not started"
    };

    private static string StatusPillClass(GameState state) => state switch
    {
        GameState.Completed  => "nn-status-pill--completed",
        GameState.InProgress => "nn-status-pill--inprogress",
        GameState.Paused     => "nn-status-pill--paused",
        _                    => "nn-status-pill--muted"
    };

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalHours >= 1)
            return $"{(int)duration.TotalHours}h {duration.Minutes}m";
        if (duration.TotalMinutes >= 1)
            return $"{(int)duration.TotalMinutes}m {duration.Seconds}s";
        return $"{(int)duration.TotalSeconds}s";
    }
}
