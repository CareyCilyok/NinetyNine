@page "/games/new"
@attribute [Authorize]
@inject IGameService GameService
@inject IVenueService VenueService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject ILogger<New> Logger
@using System.ComponentModel.DataAnnotations

<PageTitle>New Game &mdash; NinetyNine</PageTitle>

<div class="nn-page nn-new-page">
    <div class="nn-new-page__inner">
        <header class="nn-new-page__header">
            <h1 class="nn-new-page__title">Start a New Game</h1>
            <p class="nn-new-page__subtitle">Pick a venue and table size, then rack 'em up.</p>
        </header>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger" role="alert">@_errorMessage</div>
        }

        @if (_venuesLoaded && _venues.Count == 0)
        {
            <div class="nn-empty-state nn-new-page__empty">
                <h2 class="nn-empty-state__heading">No venues yet</h2>
                <p class="nn-empty-state__body">
                    Add a venue before starting a game so you can track where you play.
                </p>
                <a href="/venues/new" class="btn btn-primary">Add your first venue</a>
            </div>
        }
        else
        {
            <div class="nn-new-page__form-card">
                <EditForm Model="_model" method="post" OnValidSubmit="HandleSubmitAsync" FormName="new-game">
                    <AntiforgeryToken />
                    <DataAnnotationsValidator />

                    <div class="nn-new-page__field">
                        <label class="form-label nn-new-page__label" for="venue">Venue</label>
                        <InputSelect id="venue"
                                     class="form-select nn-new-page__select"
                                     @bind-Value="_model.VenueId"
                                     aria-required="true"
                                     aria-describedby="venue-hint">
                            <option value="">-- Select a venue --</option>
                            @foreach (var venue in _venues)
                            {
                                <option value="@venue.VenueId">
                                    @venue.Name@(!string.IsNullOrWhiteSpace(venue.Address) ? $" \u2014 {venue.Address}" : "")
                                </option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => _model.VenueId" />
                        <div id="venue-hint" class="form-text nn-new-page__hint">
                            Venue not listed? <a href="/venues/new">Add a new venue</a>.
                        </div>
                    </div>

                    <div class="nn-new-page__field">
                        <label class="form-label nn-new-page__label" id="table-size-label">Table Size</label>
                        <div class="nn-new-page__table-sizes"
                             role="group"
                             aria-labelledby="table-size-label">
                            <TableSizePicker @bind-Value="_model.TableSize" />
                        </div>
                    </div>

                    <button type="submit"
                            class="btn btn-primary nn-new-page__submit"
                            disabled="@_isSaving"
                            aria-busy="@_isSaving.ToString().ToLowerInvariant()">
                        @if (_isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"
                                  role="status"
                                  aria-hidden="true"></span>
                            <span>Starting&hellip;</span>
                        }
                        else
                        {
                            <span>Start Game</span>
                        }
                    </button>
                </EditForm>
            </div>
        }
    </div>
</div>

@code {
    [SupplyParameterFromForm(FormName = "new-game")]
    private NewGameModel _model { get; set; } = new();

    private List<Venue> _venues = [];
    private bool _venuesLoaded;
    private string _errorMessage = "";
    private bool _isSaving;
    private Guid? _playerId;

    protected override void OnInitialized()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        var claim = user?.FindFirst(ClaimNames.PlayerId)?.Value;
        if (Guid.TryParse(claim, out var id))
            _playerId = id;
    }

    protected override async Task OnInitializedAsync()
    {
        if (_playerId is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        _venues = (await VenueService.ListAsync(includePrivate: true)).ToList();
        _venuesLoaded = true;
    }

    private async Task HandleSubmitAsync()
    {
        if (_playerId is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        if (string.IsNullOrEmpty(_model.VenueId))
        {
            _errorMessage = "Please select a venue.";
            return;
        }

        _isSaving = true;
        _errorMessage = "";

        try
        {
            var game = await GameService.StartNewGameAsync(
                _playerId.Value,
                Guid.Parse(_model.VenueId),
                _model.TableSize);

            Navigation.NavigateTo($"/games/{game.GameId}/play");
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to start the game. Please try again.";
            Logger.LogWarning(ex, "Failed to start new game for player {PlayerId}.", _playerId);
            _isSaving = false;
        }
    }

    private sealed class NewGameModel
    {
        [Required(ErrorMessage = "Please select a venue.")]
        public string? VenueId { get; set; }

        public TableSize TableSize { get; set; } = TableSize.SevenFoot;
    }
}
