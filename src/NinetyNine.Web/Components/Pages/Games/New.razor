@page "/games/new"
@attribute [Authorize]
@inject IGameService GameService
@inject IVenueService VenueService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject ILogger<New> Logger
@using System.ComponentModel.DataAnnotations

<PageTitle>New Game &mdash; NinetyNine</PageTitle>

<div class="nn-page nn-new-page">
    <div class="nn-new-page__inner">
        <header class="nn-new-page__header">
            <h1 class="nn-new-page__title">Start a New Game</h1>
            <p class="nn-new-page__subtitle">
                Pick a venue and table size, then rack 'em up.
                Playing with a friend? <a href="/matches/new">Start a match instead</a>.
            </p>
        </header>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger" role="alert">@_errorMessage</div>
        }

        @if (_venuesLoaded && _venues.Count == 0)
        {
            <div class="nn-empty-state nn-new-page__empty">
                <h2 class="nn-empty-state__heading">No venues yet</h2>
                <p class="nn-empty-state__body">
                    Add a venue before starting a game so you can track where you play.
                </p>
                <a href="/venues/new" class="btn btn-primary">Add your first venue</a>
            </div>
        }
        else
        {
            <div class="nn-new-page__form-card">
                <EditForm Model="_model" method="post" OnValidSubmit="HandleSubmitAsync" FormName="new-game">
                    @* AntiforgeryToken auto-injected by Blazor SSR form handler.
                       See docs/defects.md DEF-003. *@
                    <DataAnnotationsValidator />

                    <div class="nn-new-page__field">
                        <label class="form-label nn-new-page__label" for="venue">Venue</label>
                        <InputSelect id="venue"
                                     class="form-select nn-new-page__select"
                                     @bind-Value="_model.VenueId"
                                     aria-required="true"
                                     aria-describedby="venue-hint">
                            <option value="">-- Select a venue --</option>
                            @foreach (var venue in _venues)
                            {
                                <option value="@venue.VenueId">
                                    @venue.Name@(!string.IsNullOrWhiteSpace(venue.Address) ? $" \u2014 {venue.Address}" : "")
                                </option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => _model.VenueId" />
                        <div id="venue-hint" class="form-text nn-new-page__hint">
                            Venue not listed? <a href="/venues/new">Add a new venue</a>.
                        </div>
                    </div>

                    <div class="nn-new-page__field">
                        <label class="form-label nn-new-page__label" id="table-size-label">Table Size</label>
                        @* Native <input type="radio"> inside a label gives static SSR
                           a working segmented picker: the browser handles visual selection
                           and the form POST carries the chosen TableSize via name="_model.TableSize".
                           The old <TableSizePicker> component relied on @onclick handlers
                           which never fire in static SSR — see docs/defects.md DEF-004. *@
                        <InputRadioGroup @bind-Value="_model.TableSize" Name="_model.TableSize">
                            <div class="nn-picker nn-new-page__table-sizes"
                                 role="radiogroup"
                                 aria-labelledby="table-size-label">
                                @foreach (var size in _tableSizes)
                                {
                                    var inputId = $"table-size-{size}";
                                    var isSelected = _model.TableSize == size;
                                    <label class="nn-picker__option @(isSelected ? "nn-picker__option--selected" : null)"
                                           for="@inputId">
                                        <InputRadio id="@inputId"
                                                    Value="@size"
                                                    class="nn-picker__input" />
                                        <span>@TableSizeLabel(size)</span>
                                    </label>
                                }
                            </div>
                        </InputRadioGroup>
                    </div>

                    <div class="nn-new-page__field">
                        <label class="nn-new-page__variant-row">
                            <InputCheckbox @bind-Value="_model.IsEfrenVariant"
                                           class="nn-new-page__variant-checkbox" />
                            <div class="nn-new-page__variant-copy">
                                <span class="nn-new-page__variant-title">Efren mode</span>
                                <span class="nn-new-page__variant-helper">
                                    Run-out from break — no ball in hand. Named for Efren Reyes.
                                </span>
                            </div>
                        </label>
                    </div>

                    <button type="submit"
                            class="btn btn-primary nn-new-page__submit"
                            disabled="@_isSaving"
                            aria-busy="@_isSaving.ToString().ToLowerInvariant()">
                        @if (_isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"
                                  role="status"
                                  aria-hidden="true"></span>
                            <span>Starting&hellip;</span>
                        }
                        else
                        {
                            <span>Start Game</span>
                        }
                    </button>
                </EditForm>
            </div>
        }
    </div>
</div>

@code {
    [SupplyParameterFromForm(FormName = "new-game")]
    private NewGameModel _model { get; set; } = new();

    private static readonly TableSize[] _tableSizes = Enum.GetValues<TableSize>()
        .Where(s => s != TableSize.Unknown)
        .ToArray();

    private static string TableSizeLabel(TableSize s) => s switch
    {
        TableSize.SixFoot   => "6 ft",
        TableSize.SevenFoot => "7 ft",
        TableSize.NineFoot  => "9 ft",
        TableSize.TenFoot   => "10 ft",
        _                   => s.ToString(),
    };

    private List<Venue> _venues = [];
    private bool _venuesLoaded;
    private string _errorMessage = "";
    private bool _isSaving;
    private Guid? _playerId;

    protected override void OnInitialized()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        var claim = user?.FindFirst(ClaimNames.PlayerId)?.Value;
        if (Guid.TryParse(claim, out var id))
            _playerId = id;
    }

    protected override async Task OnInitializedAsync()
    {
        if (_playerId is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        _venues = (await VenueService.ListAsync(includePrivate: true)).ToList();
        _venuesLoaded = true;
    }

    private async Task HandleSubmitAsync()
    {
        if (_playerId is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        if (string.IsNullOrEmpty(_model.VenueId))
        {
            _errorMessage = "Please select a venue.";
            return;
        }

        _isSaving = true;
        _errorMessage = "";

        Game game;
        try
        {
            game = await GameService.StartNewGameAsync(
                _playerId.Value,
                Guid.Parse(_model.VenueId),
                _model.TableSize,
                isEfrenVariant: _model.IsEfrenVariant);
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to start the game. Please try again.";
            Logger.LogWarning(ex, "Failed to start new game for player {PlayerId}.", _playerId);
            _isSaving = false;
            return;
        }

        // NavigateTo from a static SSR form handler throws NavigationException
        // as the signal-to-redirect mechanism. It MUST escape this method
        // uncaught so Blazor's infrastructure can convert it into a 302
        // redirect. Wrapping it in a try/catch (Exception) would swallow the
        // redirect and leave the user on the form page with a generic error.
        Navigation.NavigateTo($"/games/{game.GameId}/play");
    }

    private sealed class NewGameModel
    {
        [Required(ErrorMessage = "Please select a venue.")]
        public string? VenueId { get; set; }

        public TableSize TableSize { get; set; } = TableSize.SevenFoot;

        /// <summary>
        /// True when the player is choosing the Efren variant — runout from
        /// break, no ball in hand. Defaults to false (standard rules).
        /// </summary>
        public bool IsEfrenVariant { get; set; }
    }
}
