@page "/games/{GameId:guid}/play"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IGameService GameService
@inject IVenueService VenueService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject ILogger<Play> Logger

<PageTitle>
    @(_game is not null ? $"Frame {_game.CurrentFrameNumber} / 9" : "Playing") &mdash; NinetyNine
</PageTitle>

<div class="nn-page nn-play-page">

    @if (_loading)
    {
        <div class="nn-play-page__loading" aria-live="polite" aria-busy="true">
            <span class="spinner-border spinner-border-sm me-2"
                  role="status"
                  aria-hidden="true"></span>
            Loading game&hellip;
        </div>
    }
    else if (_game is null)
    {
        <div class="nn-play-page__not-found">
            <h1 class="nn-play-page__not-found-title">Game not found</h1>
            <p class="nn-play-page__not-found-body">
                This game does not exist or you do not have access to it.
            </p>
            <a href="/games" class="btn btn-outline-secondary">Back to history</a>
        </div>
    }
    else if (_game.IsCompleted)
    {
        <div class="nn-play-page__complete" aria-live="assertive">
            <div class="nn-play-page__complete-inner">
                <div class="nn-play-page__complete-icon" aria-hidden="true">&#127921;</div>
                <h1 class="nn-play-page__complete-title">Game Complete!</h1>
                <p class="nn-play-page__complete-score">
                    Final score:
                    <strong class="@(_game.IsPerfectGame ? "nn-play-page__perfect-score" : "")">
                        @_game.TotalScore
                    </strong>
                    <span class="nn-play-page__complete-max">/ 99</span>
                </p>
                @if (_game.IsPerfectGame)
                {
                    <p class="nn-play-page__perfect-label">Perfect game!</p>
                }
                <div class="nn-play-page__complete-actions">
                    <a href="/games/@GameId" class="btn btn-primary">View details</a>
                    <a href="/games/new" class="btn btn-outline-secondary">New game</a>
                </div>
            </div>
        </div>
    }
    else
    {
        @* Header strip — venue, table size, start time, status pill *@
        <header class="nn-play-page__header">
            <div class="nn-play-page__meta">
                <span class="nn-play-page__venue" aria-label="Venue">
                    @(_venueName ?? "Unknown venue")
                </span>
                <span class="nn-play-page__sep" aria-hidden="true">&middot;</span>
                <span class="nn-play-page__table-size">
                    @TableSizeLabel(_game.TableSize)
                </span>
                <span class="nn-play-page__sep" aria-hidden="true">&middot;</span>
                <time class="nn-play-page__when"
                      datetime="@_game.WhenPlayed.ToString("O")"
                      title="@_game.WhenPlayed.ToLocalTime().ToString("f")">
                    Started @_game.WhenPlayed.ToLocalTime().ToString("MMM d, h:mm tt")
                </time>
            </div>
            <div class="nn-play-page__state-pill">
                <span class="badge nn-play-page__state-badge nn-play-page__state-badge--inprogress"
                      aria-label="Game in progress">
                    In progress
                </span>
            </div>
        </header>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger nn-play-page__error" role="alert">
                @_errorMessage
            </div>
        }

        @* Turn callout card — eyebrow, "Frame N of 9", helper text, ball pair, Finish-frame button.
           CanFinish is intentionally unbound (defaults to null = enabled). A scratch break with
           no balls pocketed is a legitimate 0-point frame the player must be able to advance. *@
        <TurnCalloutCard FrameNumber="@_game.CurrentFrameNumber"
                         OnFinishFrame="HandleFinishFrame" />

        @* Score card — desktop grid + mobile picker, all driven by the in-flight buffer *@
        <section class="nn-play-page__main" aria-label="Score card">
            <ScoreCardGrid Game="_game"
                           Mode="ScoreCardMode.Edit"
                           ActiveBreakBonus="_breakBonus"
                           ActiveBallsPocketed="_ballsPocketed"
                           ActivePickerOpen="_pickerOpen"
                           ActiveLiveRunningTotal="_liveRunningTotal"
                           OnBreakToggle="HandleBreakToggle"
                           OnBallToggle="HandleBallToggle"
                           OnBallsClear="HandleBallsClear"
                           OnPickerOpen="HandlePickerOpen"
                           OnPickerClose="HandlePickerClose" />
        </section>

        @* Footer — frame indicator, running score, exit *@
        <footer class="nn-play-page__footer">
            <div class="nn-play-page__footer-info">
                <span class="nn-play-page__frame-indicator">
                    Current frame: <strong>@_game.CurrentFrameNumber</strong> / 9
                </span>
                <span class="nn-play-page__footer-sep" aria-hidden="true">&middot;</span>
                <span class="nn-play-page__score-so-far" aria-live="polite" aria-atomic="true">
                    Score so far: <strong class="nn-play-page__score-value">@_game.TotalScore</strong> / 99
                </span>
            </div>
            <a href="/games" class="nn-play-page__exit-link">Exit to history</a>
        </footer>
    }
</div>

@code {
    [Parameter] public Guid GameId { get; set; }

    private Game? _game;
    private bool _loading = true;
    private string _errorMessage = "";
    private string? _venueName;
    private Guid? _playerId;

    // ── In-flight buffer for the active frame ────────────────────────────────
    // Local-only state. Refreshing the page discards in-flight edits — the
    // README's data model only persists completed frames server-side. This
    // matches the v2 mockup behavior.

    private bool _breakBonus;
    private HashSet<int> _ballsPocketed = new();
    private bool _pickerOpen;

    // ── Initial load ─────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        var claim = user?.FindFirst(ClaimNames.PlayerId)?.Value;
        if (Guid.TryParse(claim, out var id))
            _playerId = id;
    }

    protected override async Task OnInitializedAsync()
    {
        if (_playerId is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        await LoadGameAsync();
        _loading = false;
    }

    private async Task LoadGameAsync()
    {
        var game = await GameService.GetGameAsync(GameId);

        // Ownership guard: don't reveal existence via 403 — just show "not found".
        if (game is null || game.PlayerId != _playerId)
        {
            _game = null;
            return;
        }

        // Redirect completed games to the details page.
        if (game.IsCompleted)
        {
            Navigation.NavigateTo($"/games/{GameId}", forceLoad: false);
            return;
        }

        // Defensive: initialize frames if somehow still NotStarted.
        if (game.GameState == GameState.NotStarted)
        {
            game.InitializeFrames();
            Logger.LogWarning(
                "Game {GameId} was in NotStarted state on Play page load — frames initialized defensively.",
                GameId);
        }

        _game = game;

        try
        {
            var venue = await VenueService.GetAsync(game.VenueId);
            _venueName = venue?.Name;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Could not resolve venue {VenueId} for game {GameId}.", game.VenueId, GameId);
        }
    }

    // ── Computed values ──────────────────────────────────────────────────────

    /// <summary>
    /// Convert a set of pocketed ball numbers to the BallCount points value
    /// the model expects: the 9-ball is worth 2 points, every other ball is
    /// worth 1. Pocketing all 9 balls scores 8 + 2 = 10, which is the model's
    /// per-frame BallCount ceiling.
    /// </summary>
    private static int BallPoints(IReadOnlySet<int>? balls) =>
        balls is null ? 0 : balls.Sum(b => b == 9 ? 2 : 1);

    /// <summary>
    /// Running total displayed on the active cell: completed frames' running
    /// total + (in-flight break bonus + ball points). Recomputed on every
    /// buffer change.
    /// </summary>
    private int? _liveRunningTotal => _game is null ? null : ComputeLiveRunningTotal();

    private int ComputeLiveRunningTotal()
    {
        var completedTotal = _game!.RunningTotal; // last completed frame's RunningTotal, or 0
        var inFlight = (_breakBonus ? 1 : 0) + BallPoints(_ballsPocketed);
        return completedTotal + inFlight;
    }

    // ── Event handlers (in-flight buffer manipulation) ───────────────────────

    private void HandleBreakToggle()
    {
        _breakBonus = !_breakBonus;
    }

    private void HandleBallToggle(int ballNumber)
    {
        if (!_ballsPocketed.Add(ballNumber))
            _ballsPocketed.Remove(ballNumber);
    }

    private void HandleBallsClear()
    {
        _ballsPocketed.Clear();
    }

    private void HandlePickerOpen() => _pickerOpen = true;
    private void HandlePickerClose() => _pickerOpen = false;

    // ── Finish frame: persist the in-flight buffer, reset, advance ───────────

    private async Task HandleFinishFrame()
    {
        if (_game is null) return;

        _errorMessage = "";

        try
        {
            var frameNumber = _game.CurrentFrameNumber;
            var breakBonus = _breakBonus ? 1 : 0;
            // 9-ball is worth 2 points; all other balls 1.
            var ballCount = BallPoints(_ballsPocketed);

            _game = await GameService.RecordFrameAsync(
                GameId, frameNumber, breakBonus, ballCount, notes: null);

            // Reset the buffer for the next frame.
            ResetBuffer();
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to record the frame. Please try again.";
            Logger.LogWarning(ex,
                "Failed to record frame for game {GameId}.", GameId);
        }
    }

    private void ResetBuffer()
    {
        _breakBonus = false;
        _ballsPocketed = new();
        _pickerOpen = false;
    }

    private static string TableSizeLabel(TableSize size) => size switch
    {
        TableSize.SixFoot   => "6 ft",
        TableSize.SevenFoot => "7 ft",
        TableSize.NineFoot  => "9 ft",
        TableSize.TenFoot   => "10 ft",
        _                   => size.ToString()
    };
}
