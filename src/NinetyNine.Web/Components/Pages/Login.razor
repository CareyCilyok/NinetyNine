@page "/login"
@inject IConfiguration Configuration
@inject IPlayerRepository PlayerRepository
@inject IWebHostEnvironment Environment
@using NinetyNine.Model
@using NinetyNine.Repository.Repositories
@using NinetyNine.Services

<PageTitle>Sign In &mdash; NinetyNine</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-7 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body p-5">
                <h1 class="h3 card-title mb-3 text-center">Sign In</h1>

                @if (IsMockEnabled)
                {
                    <div class="alert alert-warning small" role="alert">
                        <strong>Mock auth mode.</strong> OAuth is bypassed for UX prototyping.
                        Pick a test player below or create a new account — no credentials required.
                    </div>

                    <h2 class="h5 mt-4 mb-3">Sign in as a test player</h2>

                    @if (_mockPlayers.Count == 0)
                    {
                        <p class="text-muted small">No seeded players found. Check the app logs for seeder errors.</p>
                    }
                    else
                    {
                        <div class="list-group mb-4">
                            @foreach (var player in _mockPlayers)
                            {
                                <a href="@($"/mock/signin-as?playerId={player.PlayerId}")"
                                   class="list-group-item list-group-item-action d-flex align-items-center gap-3">
                                    <AvatarImage DisplayName="@player.DisplayName"
                                                 AvatarUrl="@(player.Avatar is not null ? $"/api/avatars/{player.PlayerId}" : null)"
                                                 SizePx="48" />
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold">@player.DisplayName</div>
                                        @if (player.Visibility.RealName && !string.IsNullOrEmpty(player.FirstName))
                                        {
                                            <div class="text-muted small">@player.FirstName @player.LastName</div>
                                        }
                                    </div>
                                    <span class="btn btn-sm btn-outline-primary">Sign in</span>
                                </a>
                            }
                        </div>
                    }

                    <h2 class="h5 mt-4 mb-3">Or create a new account</h2>
                    <a href="/mock/signin-new" class="btn btn-primary w-100">
                        Create new test account
                    </a>
                }
                else
                {
                    <p class="text-muted mb-4 text-center">
                        Use your Google account to sign in. No password needed.
                    </p>

                    <a href="/auth/challenge?provider=Google"
                       class="btn btn-outline-danger btn-lg w-100 d-flex align-items-center justify-content-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 48 48" aria-hidden="true">
                            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                        </svg>
                        Sign in with Google
                    </a>

                    <p class="mt-4 text-muted small text-center">
                        New here? You will be prompted to pick a display name after signing in.
                    </p>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<Player> _mockPlayers = new();

    private bool IsMockEnabled =>
        Environment.IsDevelopment() && Configuration.GetValue<bool>("Auth:Mock:Enabled");

    protected override async Task OnInitializedAsync()
    {
        if (!IsMockEnabled) return;

        foreach (var displayName in IDataSeeder.TestPlayerDisplayNames)
        {
            var player = await PlayerRepository.GetByDisplayNameAsync(displayName);
            if (player is not null) _mockPlayers.Add(player);
        }
    }
}
