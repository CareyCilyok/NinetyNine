@page "/login"
@inject IConfiguration Configuration
@inject IPlayerRepository PlayerRepository
@inject IWebHostEnvironment Environment
@inject IAuthService AuthService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject ILogger<Login> Logger
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using NinetyNine.Model
@using NinetyNine.Repository.Repositories
@using NinetyNine.Services
@using NinetyNine.Services.Auth
@using NinetyNine.Web.Auth

<PageTitle>Sign in &mdash; NinetyNine</PageTitle>

<div class="nn-page nn-auth-page">
    <div class="nn-auth-card">
        <div class="nn-auth-card__wordmark" aria-hidden="true">NinetyNine</div>
        <h1 class="nn-auth-card__title">Sign in to NinetyNine</h1>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger" role="alert">
                @_errorMessage
                @if (_showResendLink)
                {
                    <div class="mt-2">
                        <a href="/resend-verification" class="alert-link">Resend verification email</a>
                    </div>
                }
            </div>
        }

        <EditForm Model="_model" method="post" OnValidSubmit="HandleSubmitAsync" FormName="login">
            @* AntiforgeryToken is injected automatically by the Blazor SSR form
               handler when EditForm has method="post" + FormName. An explicit
               <AntiforgeryToken /> would emit a duplicate hidden field and make
               token validation fail with 400. See docs/defects.md DEF-003. *@
            <DataAnnotationsValidator />

            <div class="form-group">
                <label class="form-label" for="identifier">Email or display name</label>
                <InputText id="identifier" type="text"
                           class="form-control"
                           @bind-Value="_model.EmailOrDisplayName"
                           autocomplete="username" required />
                <ValidationMessage For="() => _model.EmailOrDisplayName" />
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Password</label>
                <InputText id="password" type="password"
                           class="form-control"
                           @bind-Value="_model.Password"
                           autocomplete="current-password" required />
                <ValidationMessage For="() => _model.Password" />
            </div>

            <button type="submit" class="btn btn-primary w-100" disabled="@_isSubmitting">
                @if (_isSubmitting)
                {
                    <span>Signing in&hellip;</span>
                }
                else
                {
                    <span>Sign in</span>
                }
            </button>
        </EditForm>

        <p class="nn-auth-card__links">
            <a href="/forgot-password">Forgot password?</a>
            <span class="nn-auth-card__links-sep">&middot;</span>
            <a href="/resend-verification">Resend verification email</a>
        </p>

        <p class="nn-auth-card__aside">
            New to NinetyNine? <a href="/register">Create an account</a>.
        </p>

        @* ================================================================
           DEVELOPMENT ONLY — mock auth picker.
           Visible only when Auth:Mock:Enabled = true in appsettings.Development.json.
           This bypasses real authentication for UX prototyping. Removed in production.
           ================================================================ *@
        @if (IsMockEnabled)
        {
            <hr class="nn-auth-card__divider" />

            <div class="nn-auth-mock" role="region" aria-label="Development mock authentication">
                <div class="alert alert-warning small" role="alert">
                    <strong>Development only.</strong> Mock auth is enabled. OAuth is bypassed for UX prototyping.
                    Pick a test player below &mdash; no credentials required.
                </div>

                <h2 class="nn-auth-mock__heading">Sign in as a test player</h2>

                @if (_mockPlayers.Count == 0)
                {
                    <p class="nn-auth-mock__empty">No seeded players found. Check the app logs for seeder errors.</p>
                }
                else
                {
                    <div class="list-group nn-auth-mock__list">
                        @foreach (var player in _mockPlayers)
                        {
                            <a href="@($"/mock/signin-as?playerId={player.PlayerId}")"
                               class="list-group-item list-group-item-action d-flex align-items-center gap-3">
                                <AvatarImage DisplayName="@player.DisplayName"
                                             AvatarUrl="@(player.Avatar is not null ? $"/api/avatars/{player.PlayerId}" : null)"
                                             SizePx="48" />
                                <div class="flex-grow-1">
                                    <div class="fw-semibold">@player.DisplayName</div>
                                    @if (player.Visibility.RealNameAudience != Audience.Private && !string.IsNullOrEmpty(player.FirstName))
                                    {
                                        <div class="text-muted small">@player.FirstName @player.LastName</div>
                                    }
                                </div>
                                <span class="btn btn-sm btn-outline-primary">Sign in</span>
                            </a>
                        }
                    </div>
                }

                <h2 class="nn-auth-mock__heading mt-3">Or create a new test account</h2>
                <a href="/mock/signin-new" class="btn btn-primary w-100">
                    Create new test account
                </a>
            </div>
        }
    </div>
</div>

@code {
    [SupplyParameterFromForm(FormName = "login")]
    private LoginModel _model { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private string _errorMessage = "";
    private bool _showResendLink;
    private bool _isSubmitting;

    private List<Player> _mockPlayers = new();

    private bool IsMockEnabled =>
        Environment.IsDevelopment() && Configuration.GetValue<bool>("Auth:Mock:Enabled");

    protected override async Task OnInitializedAsync()
    {
        if (!IsMockEnabled) return;

        foreach (var displayName in IDataSeeder.TestPlayerDisplayNames)
        {
            var player = await PlayerRepository.GetByDisplayNameAsync(displayName);
            if (player is not null) _mockPlayers.Add(player);
        }
    }

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = "";
        _showResendLink = false;

        try
        {
            var result = await AuthService.LoginAsync(_model.EmailOrDisplayName, _model.Password);

            if (result.Success && result.Value is Player player)
            {
                var http = HttpContextAccessor.HttpContext!;
                await AuthEndpoints.SignInPlayerAsync(http, player);
                Navigation.NavigateTo(ReturnUrl ?? "/", forceLoad: true);
                return;
            }

            var error = result.ErrorMessage ?? "Invalid credentials.";

            if (error.Contains("locked", StringComparison.OrdinalIgnoreCase))
            {
                _errorMessage = "Too many failed attempts. Try again in 15 minutes.";
            }
            else if (error.Contains("verif", StringComparison.OrdinalIgnoreCase))
            {
                _errorMessage = "Your email address has not been verified. Please check your inbox.";
                _showResendLink = true;
            }
            else
            {
                _errorMessage = "Invalid credentials.";
            }

            Logger.LogInformation(
                "Login failed for {Identifier}: {Error}", _model.EmailOrDisplayName, error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private sealed class LoginModel
    {
        // Either an email (containing '@') or a display name. The dispatch
        // happens inside AuthService.LoginAsync — no front-end format check
        // needed here beyond Required.
        [Required(ErrorMessage = "Email or display name is required.")]
        public string EmailOrDisplayName { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        public string Password { get; set; } = "";
    }
}
