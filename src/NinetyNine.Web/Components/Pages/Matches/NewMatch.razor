@page "/matches/new"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMatchService MatchService
@inject IVenueService VenueService
@inject IFriendService FriendService
@inject IPlayerRepository PlayerRepository
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@using System.ComponentModel.DataAnnotations

<PageTitle>New Match &mdash; NinetyNine</PageTitle>

<div class="nn-page nn-new-match-page">
    <div class="nn-new-match-page__inner">
        <header class="nn-new-match-page__header">
            <h1 class="nn-new-match-page__title">Start a match</h1>
            <p class="nn-new-match-page__subtitle">
                Solo or multi-player. Each player runs their own 9-frame game; multi-player matches alternate innings frame-by-frame.
            </p>
        </header>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger" role="alert">@_errorMessage</div>
        }

        @if (_venues.Count == 0)
        {
            <div class="nn-empty-state">
                <p>Add a venue before starting a match.</p>
                <a href="/venues/new" class="btn btn-primary">Add a venue</a>
            </div>
        }
        else
        {
            @if (_opponents.Count == 0)
            {
                <div class="alert alert-info" role="status">
                    You don't have any friends yet — you can still start a
                    <strong>solo match</strong> below.
                    <a href="/friends" class="alert-link">Find friends</a>
                    to add opponents to future matches.
                </div>
            }

            <EditForm Model="_model"
                      OnValidSubmit="HandleSubmitAsync">
                <DataAnnotationsValidator />

                @* ─ Roster: 1–4 players with per-player Efren ───────────── *@
                <fieldset class="nn-new-match-page__roster">
                    <legend class="form-label">Players</legend>
                    <p class="form-text nn-new-match-page__roster-hint">
                        Add up to 3 friends to play alongside you (1–4 players total).
                        Innings rotate seat 1 → seat 2 → … → seat 1 frame 2 → … .
                        Efren mode is per player — flip the gold ring on whoever
                        is running it out from where the cue ball lies.
                    </p>
                    <p class="form-text nn-new-match-page__roster-solo-hint">
                        <strong>Solo match?</strong> Just leave the opponent slot
                        empty (or remove it) — you'll record your own 9-frame
                        game with no opponent.
                    </p>

                    @* Seat 0: the creator (you) — fixed slot. *@
                    <div class="nn-new-match-page__roster-row nn-new-match-page__roster-row--you">
                        <span class="nn-new-match-page__roster-seat">1.</span>
                        <span class="nn-new-match-page__roster-name">You</span>
                        <label class="nn-new-match-page__efren-toggle">
                            <InputCheckbox @bind-Value="_model.CreatorEfren" />
                            <span>Efren</span>
                        </label>
                    </div>

                    @for (int i = 0; i < _model.OpponentSeats.Count; i++)
                    {
                        var idx = i;            // capture for lambda
                        var seat = _model.OpponentSeats[idx];
                        var seatNumber = idx + 2;       // seat 0 is "you" → row label 1
                        <div class="nn-new-match-page__roster-row">
                            <span class="nn-new-match-page__roster-seat">@seatNumber.</span>
                            <InputSelect class="form-select nn-new-match-page__roster-select"
                                         @bind-Value="seat.PlayerId">
                                <option value="@Guid.Empty">-- Select player --</option>
                                @foreach (var p in _opponents)
                                {
                                    <option value="@p.PlayerId">@p.DisplayName</option>
                                }
                            </InputSelect>
                            <label class="nn-new-match-page__efren-toggle">
                                <InputCheckbox @bind-Value="seat.IsEfrenVariant" />
                                <span>Efren</span>
                            </label>
                        </div>
                    }

                    <div class="nn-new-match-page__roster-actions">
                        <button type="button" class="btn btn-ghost btn-sm"
                                disabled="@(!CanAddSeat)"
                                @onclick="AddSeat">
                            + Add player
                        </button>
                        <button type="button" class="btn btn-ghost btn-sm"
                                disabled="@(!CanRemoveSeat)"
                                @onclick="RemoveLastSeat">
                            − Remove last
                        </button>
                    </div>
                </fieldset>

                <div class="form-group">
                    <label class="form-label" for="venue">Venue</label>
                    <InputSelect id="venue" class="form-select"
                                 @bind-Value="_model.VenueId">
                        <option value="@Guid.Empty">-- Select venue --</option>
                        @foreach (var v in _venues)
                        {
                            <option value="@v.VenueId">@v.Name</option>
                        }
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label class="form-label">Break method</label>
                    <InputRadioGroup @bind-Value="_model.BreakMethod" Name="_model.BreakMethod">
                        <div class="nn-new-match-page__radio-group" role="radiogroup">
                            @foreach (var method in _breakMethods)
                            {
                                var id = $"break-{method}";
                                <label class="nn-new-match-page__radio-option" for="@id">
                                    <InputRadio id="@id" Value="@method" />
                                    <span>@BreakMethodLabel(method)</span>
                                </label>
                            }
                        </div>
                    </InputRadioGroup>
                </div>

                <div class="form-group">
                    <label class="form-label" for="table-size">Table size</label>
                    <InputSelect id="table-size" class="form-select"
                                 @bind-Value="_model.TableSize">
                        <option value="@TableSize.SixFoot">6 ft</option>
                        <option value="@TableSize.SevenFoot">7 ft</option>
                        <option value="@TableSize.NineFoot">9 ft</option>
                        <option value="@TableSize.TenFoot">10 ft</option>
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label class="form-label" for="table-number">Table number (optional)</label>
                    <InputNumber id="table-number" class="form-control"
                                 @bind-Value="_model.TableNumber" />
                </div>

                <div class="form-group">
                    <label class="form-label" for="stakes">For bragging rights (optional)</label>
                    <InputText id="stakes" class="form-control"
                               @bind-Value="_model.Stakes"
                               placeholder="e.g., loser buys next round" />
                    <div class="form-text">
                        Private — only participants see this. Never shown publicly.
                    </div>
                </div>

                <div class="nn-new-match-page__actions">
                    <button type="submit" class="btn btn-primary">Start match</button>
                    <a href="/games/new" class="btn btn-ghost">Start a solo game instead</a>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    // Plain field — InteractiveServer rendering means the form lives in the
    // SignalR-backed component lifetime, not a per-request POST cycle.
    // [SupplyParameterFromForm] is the static-SSR mechanism and would null
    // this out on the initial GET when the model has nested List<T>.
    private NewMatchModel _model = new();

    private List<Venue> _venues = [];
    private List<Player> _opponents = [];
    private Guid _creatorId;
    private string _errorMessage = "";

    // Matches accept 1–4 players total. Seat 0 is the creator, so opponent
    // slots range from 0 (solo match — record your own 9-frame game) to 3
    // (4-player concurrent). The roster shows one empty opponent slot by
    // default to make the "add a friend" path discoverable, but the user
    // can remove it for a solo match (or just leave it unpicked — the
    // submit handler skips empty slots).
    private const int MaxOpponents = 3;
    private const int MinOpponents = 0;

    private bool CanAddSeat =>
        _opponents.Count > 0 &&
        _model.OpponentSeats.Count < MaxOpponents;

    private bool CanRemoveSeat =>
        _model.OpponentSeats.Count > MinOpponents;

    private static readonly BreakMethod[] _breakMethods =
    [
        BreakMethod.Lagged,
        BreakMethod.CoinFlip,
        BreakMethod.MutualAgreement,
    ];

    private static string BreakMethodLabel(BreakMethod m) => m switch
    {
        BreakMethod.Lagged => "Lag for break",
        BreakMethod.CoinFlip => "Coin flip",
        BreakMethod.MutualAgreement => "Agreed",
        _ => m.ToString(),
    };

    protected override async Task OnInitializedAsync()
    {
        var claim = HttpContextAccessor.HttpContext?.User?.FindFirst(ClaimNames.PlayerId)?.Value;
        if (!Guid.TryParse(claim, out var id))
        {
            Navigation.NavigateTo("/login?ReturnUrl=/matches/new", forceLoad: true);
            return;
        }
        _creatorId = id;

        _venues = (await VenueService.ListAsync(includePrivate: true)).ToList();
        _opponents = (await FriendService.ListFriendsAsync(_creatorId)).ToList();

        // Default roster: one empty opponent slot when the user has at
        // least one friend (= 2-player match), so the "add a friend" path
        // is discoverable. With no friends, default to zero opponent seats
        // (true solo) — an empty slot would render an opponent dropdown
        // with only the placeholder, which is confusing.
        if (_model.OpponentSeats.Count == 0 && _opponents.Count > 0)
            _model.OpponentSeats.Add(new OpponentSeatModel());
    }

    private void AddSeat()
    {
        if (CanAddSeat)
            _model.OpponentSeats.Add(new OpponentSeatModel());
    }

    private void RemoveLastSeat()
    {
        if (CanRemoveSeat)
            _model.OpponentSeats.RemoveAt(_model.OpponentSeats.Count - 1);
    }

    private async Task HandleSubmitAsync()
    {
        if (_model.VenueId == Guid.Empty)
        {
            _errorMessage = "Venue is required.";
            return;
        }

        // Build the player setup list. Seat 0 is the creator with their
        // Efren toggle; seats 1+ are the opponent rows. Skip rows whose
        // PlayerId hasn't been chosen (the user may have added a slot
        // and never picked anyone).
        var setups = new List<ConcurrentMatchPlayerSetup>
        {
            new(_creatorId, _model.CreatorEfren),
        };
        setups.AddRange(_model.OpponentSeats
            .Where(s => s.PlayerId != Guid.Empty)
            .Select(s => new ConcurrentMatchPlayerSetup(s.PlayerId, s.IsEfrenVariant)));

        if (setups.Count < 1)
        {
            // Should be unreachable since the creator is always seat 0,
            // but defend against the empty case anyway.
            _errorMessage = "Could not resolve the current player.";
            return;
        }

        // Defensive UI-side check — the service will also enforce.
        if (setups.Select(s => s.PlayerId).Distinct().Count() != setups.Count)
        {
            _errorMessage = "Each seat must be a different player.";
            return;
        }

        var result = await MatchService.CreateConcurrentMatchAsync(
            creatorPlayerId: _creatorId,
            players: setups,
            venueId: _model.VenueId,
            tableSize: _model.TableSize,
            breakMethod: _model.BreakMethod,
            tableNumber: _model.TableNumber,
            stakes: _model.Stakes);

        if (!result.Success)
        {
            _errorMessage = result.ErrorMessage ?? "Could not create the match.";
            return;
        }

        Navigation.NavigateTo($"/matches/{result.Value!.MatchId}/play");
    }

    private sealed class NewMatchModel
    {
        public bool CreatorEfren { get; set; }
        public List<OpponentSeatModel> OpponentSeats { get; set; } = [];

        public Guid VenueId { get; set; }
        public BreakMethod BreakMethod { get; set; } = BreakMethod.Lagged;
        public TableSize TableSize { get; set; } = TableSize.SevenFoot;
        public int? TableNumber { get; set; }
        public string? Stakes { get; set; }
    }

    private sealed class OpponentSeatModel
    {
        public Guid PlayerId { get; set; }
        public bool IsEfrenVariant { get; set; }
    }
}
