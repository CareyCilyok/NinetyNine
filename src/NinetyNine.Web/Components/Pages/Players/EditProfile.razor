@page "/players/me/edit"
@attribute [Authorize]
@inject IPlayerService PlayerService
@inject IPlayerRepository PlayerRepository
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject ILogger<EditProfile> Logger
@using System.ComponentModel.DataAnnotations
@using System.Text.RegularExpressions

<PageTitle>Edit Profile &mdash; NinetyNine</PageTitle>

<div class="nn-page nn-edit-profile-page">
    <div class="nn-edit-profile-page__inner">

        <header class="nn-edit-profile-page__header">
            <h1 class="nn-edit-profile-page__title">Edit Profile</h1>
            @if (_player is not null)
            {
                <a href="/players/@_playerId"
                   class="btn btn-outline-secondary btn-sm nn-edit-profile-page__view-btn">
                    View profile
                </a>
            }
        </header>

        @if (_loadError)
        {
            <div class="alert alert-danger" role="alert">
                Profile not found. You may have been signed out.
                <a href="/login" class="alert-link">Sign in again</a>
            </div>
        }
        else if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger" role="alert">@_errorMessage</div>
        }

        @* ── One-time migration banner (Sprint 3 S3.4). Lives outside
           every EditForm so it can host its own top-level dismiss form
           without nesting. *@
        @if (_showMigrationBanner)
        {
            <div class="alert alert-info nn-edit-profile-page__migration-banner" role="status">
                <p>
                    We've moved from simple on/off visibility to four audience
                    tiers. Anything you had visible is now set to <strong>Friends</strong>
                    — widen or narrow each field any time.
                </p>
                <EditForm Model="_dismissModel" method="post"
                          OnValidSubmit="HandleDismissMigrationBannerAsync"
                          FormName="dismiss-migration-banner">
                    <button type="submit" class="btn btn-sm btn-ghost">
                        Got it
                    </button>
                </EditForm>
            </div>
        }

        @* ── Avatar section (separate multipart form, SSR-compatible) ──── *@
        <section class="nn-edit-profile-page__card nn-edit-profile-page__avatar-section"
                 aria-label="Avatar">
            <h2 class="nn-edit-profile-page__card-title">Avatar</h2>

            <div class="nn-edit-profile-page__avatar-row">
                <div class="nn-edit-profile-page__avatar-preview">
                    @if (_player is not null)
                    {
                        <AvatarImage AvatarUrl="@_avatarUrl"
                                     DisplayName="@(_player.DisplayName)"
                                     SizePx="80" />
                    }
                </div>

                <div class="nn-edit-profile-page__avatar-controls">
                    @* Avatar upload uses a separate multipart form that posts directly to
                       the upload API endpoint. Static-SSR forms cannot handle
                       multipart/form-data through [SupplyParameterFromForm], so the file
                       upload lives in its own HTML form with enctype="multipart/form-data".
                       The endpoint reads the IFormFile, calls IPlayerService.SetAvatarAsync,
                       and redirects back to this page. *@
                    <form method="post"
                          action="/api/avatars/upload"
                          enctype="multipart/form-data"
                          class="nn-edit-profile-page__upload-form">
                        @* Antiforgery token injected via the AntiforgeryToken tag helper;
                           for a plain HTML form outside EditForm we use the IAntiforgery
                           service — but the simplest approach for SSR is to include the
                           token via hidden input rendered from the Antiforgery service.
                           The endpoint validates it via [ValidateAntiForgeryToken] or
                           the UseAntiforgery middleware already applied globally. *@
                        <input type="hidden" name="__RequestVerificationToken"
                               value="@_antiforgeryToken" />

                        <label class="form-label visually-hidden" for="avatar-file">
                            Upload new avatar (PNG, JPEG, or WebP, max 2 MB)
                        </label>
                        <input type="file"
                               id="avatar-file"
                               name="file"
                               accept="image/png,image/jpeg,image/webp"
                               class="form-control nn-edit-profile-page__file-input"
                               aria-describedby="avatar-hint" />
                        <div id="avatar-hint" class="form-text nn-edit-profile-page__file-hint">
                            PNG, JPEG, or WebP &mdash; max 2 MB
                        </div>

                        <button type="submit"
                                class="btn btn-outline-primary btn-sm mt-2"
                                aria-label="Upload new avatar">
                            Upload avatar
                        </button>
                    </form>

                    @if (_player?.Avatar is not null)
                    {
                        <form method="post"
                              action="/api/avatars/remove"
                              class="nn-edit-profile-page__remove-form">
                            <input type="hidden" name="__RequestVerificationToken"
                                   value="@_antiforgeryToken" />
                            <button type="submit"
                                    class="btn btn-outline-danger btn-sm"
                                    aria-label="Remove current avatar">
                                Remove avatar
                            </button>
                        </form>
                    }
                </div>
            </div>
        </section>

        @* ── Main profile form ─────────────────────────────────────────── *@
        <section class="nn-edit-profile-page__card nn-edit-profile-page__form-section">
            <EditForm Model="_model"
                      method="post"
                      OnValidSubmit="HandleSubmitAsync"
                      FormName="edit-profile">
                @* AntiforgeryToken auto-injected by Blazor SSR form handler.
                   See docs/defects.md DEF-003. *@
                <DataAnnotationsValidator />

                @* Display name *@
                <div class="nn-edit-profile-page__field-group">
                    <h2 class="nn-edit-profile-page__card-title">Display Name</h2>

                    <div class="nn-edit-profile-page__field">
                        <label class="form-label" for="display-name">
                            Display name
                            <span class="nn-edit-profile-page__required" aria-hidden="true">*</span>
                        </label>
                        <InputText id="display-name"
                                   class="form-control"
                                   @bind-Value="_model.DisplayName"
                                   autocomplete="username"
                                   aria-required="true"
                                   aria-describedby="display-name-hint" />
                        <div id="display-name-hint" class="form-text">
                            2&ndash;32 characters; letters, digits, underscores, and hyphens only.
                        </div>
                        <ValidationMessage For="() => _model.DisplayName" />
                    </div>
                </div>

                @* Email address — read-only *@
                <div class="nn-edit-profile-page__field-group">
                    <h2 class="nn-edit-profile-page__card-title">Email Address</h2>

                    <div class="nn-edit-profile-page__field">
                        <p class="nn-edit-profile-page__readonly-label">Email</p>
                        <p class="nn-edit-profile-page__readonly-value"
                           aria-label="Email address: @(_player?.EmailAddress ?? string.Empty)">
                            @(_player?.EmailAddress ?? string.Empty)
                        </p>
                        <p class="form-text nn-edit-profile-page__email-note">
                            Email changes are not yet supported. Contact support if you need to
                            update your email address.
                        </p>
                    </div>
                </div>

                @* Personal information *@
                <div class="nn-edit-profile-page__field-group">
                    <h2 class="nn-edit-profile-page__card-title">Personal Information</h2>
                    <p class="nn-edit-profile-page__section-hint">
                        All fields are optional. Use the visibility toggles to control what
                        other players can see on your public profile.
                    </p>

                    <div class="nn-edit-profile-page__name-row">
                        <div class="nn-edit-profile-page__field">
                            <label class="form-label" for="first-name">First name</label>
                            <InputText id="first-name"
                                       class="form-control"
                                       @bind-Value="_model.FirstName"
                                       autocomplete="given-name" />
                        </div>
                        <div class="nn-edit-profile-page__field">
                            <label class="form-label" for="middle-name">Middle name</label>
                            <InputText id="middle-name"
                                       class="form-control"
                                       @bind-Value="_model.MiddleName"
                                       autocomplete="additional-name" />
                        </div>
                        <div class="nn-edit-profile-page__field">
                            <label class="form-label" for="last-name">Last name</label>
                            <InputText id="last-name"
                                       class="form-control"
                                       @bind-Value="_model.LastName"
                                       autocomplete="family-name" />
                        </div>
                    </div>

                    <div class="nn-edit-profile-page__field">
                        <label class="form-label" for="phone-number">Phone number</label>
                        <InputText id="phone-number"
                                   class="form-control"
                                   @bind-Value="_model.PhoneNumber"
                                   autocomplete="tel"
                                   inputmode="tel" />
                    </div>
                </div>

                @* Privacy / audience (Sprint 3 S3.4) *@
                <div class="nn-edit-profile-page__field-group">
                    <h2 class="nn-edit-profile-page__card-title">Privacy</h2>
                    <p class="nn-edit-profile-page__section-hint">
                        Pick who can see each field. Tiers widen left to right:
                        <strong>Private</strong> keeps a field to yourself,
                        <strong>Friends</strong> shares with mutual friends,
                        <strong>Communities</strong> extends to pool players who share a community with you, and
                        <strong>Public</strong> lets any signed-in pool player see it.
                    </p>

                    <div class="nn-edit-profile-page__audience-grid">
                        <div class="nn-edit-profile-page__audience-row">
                            <label class="nn-edit-profile-page__audience-label">Real name</label>
                            <AudiencePicker Value="@_model.RealNameAudience"
                                            Name="_model.RealNameAudience"
                                            AriaLabel="Real name audience" />
                        </div>
                        <div class="nn-edit-profile-page__audience-row">
                            <label class="nn-edit-profile-page__audience-label">Email address</label>
                            <AudiencePicker Value="@_model.EmailAudience"
                                            Name="_model.EmailAudience"
                                            AriaLabel="Email audience" />
                        </div>
                        <div class="nn-edit-profile-page__audience-row">
                            <label class="nn-edit-profile-page__audience-label">Phone number</label>
                            <AudiencePicker Value="@_model.PhoneAudience"
                                            Name="_model.PhoneAudience"
                                            AriaLabel="Phone audience" />
                        </div>
                        <div class="nn-edit-profile-page__audience-row">
                            <label class="nn-edit-profile-page__audience-label">Avatar</label>
                            <AudiencePicker Value="@_model.AvatarAudience"
                                            Name="_model.AvatarAudience"
                                            AriaLabel="Avatar audience" />
                        </div>
                    </div>
                </div>

                @* Submit *@
                <div class="nn-edit-profile-page__actions">
                    <button type="submit"
                            class="btn btn-primary nn-edit-profile-page__submit-btn"
                            disabled="@_isSaving"
                            aria-busy="@_isSaving.ToString().ToLowerInvariant()">
                        @if (_isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"
                                  role="status"
                                  aria-hidden="true"></span>
                            <span>Saving&hellip;</span>
                        }
                        else
                        {
                            <span>Save Changes</span>
                        }
                    </button>
                    <a href="/players/@_playerId"
                       class="btn btn-outline-secondary">
                        Cancel
                    </a>
                </div>
            </EditForm>
        </section>

    </div>
</div>

@code {
    [SupplyParameterFromForm(FormName = "edit-profile")]
    private EditProfileModel _model { get; set; } = new();

    [SupplyParameterFromForm(FormName = "dismiss-migration-banner")]
    private EmptyModel _dismissModel { get; set; } = new();

    private Player? _player;
    private string? _avatarUrl;
    private string _errorMessage = "";
    private bool _loadError;
    private bool _isSaving;
    private bool _showMigrationBanner;
    private Guid? _playerId;
    private string _antiforgeryToken = "";

    private sealed class EmptyModel { }

    protected override void OnInitialized()
    {
        // Extract PlayerId from the auth cookie claim. Must run synchronously
        // so the value is available when the form binding runs on POST.
        var claim = HttpContextAccessor.HttpContext?.User.FindFirst(ClaimNames.PlayerId)?.Value;
        if (Guid.TryParse(claim, out var id))
            _playerId = id;

        // Extract the antiforgery token for the plain-HTML avatar forms.
        // The token is already validated globally by UseAntiforgery(); we just
        // need its string value to embed in the hidden input.
        var antiforgery = HttpContextAccessor.HttpContext?.RequestServices
            .GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();
        if (antiforgery is not null && HttpContextAccessor.HttpContext is not null)
        {
            var tokens = antiforgery.GetAndStoreTokens(HttpContextAccessor.HttpContext);
            _antiforgeryToken = tokens.RequestToken ?? "";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (_playerId is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        _player = await PlayerRepository.GetByIdAsync(_playerId.Value);

        if (_player is null)
        {
            _loadError = true;
            return;
        }

        // Populate the form model from the player (only on GET, not on POST
        // where [SupplyParameterFromForm] will have already populated _model).
        var isPost = HttpContextAccessor.HttpContext?.Request.Method
            .Equals("POST", StringComparison.OrdinalIgnoreCase) == true;

        if (!isPost)
            _model = EditProfileModel.From(_player);

        if (_player.Avatar is not null)
            _avatarUrl = $"/api/avatars/{_player.PlayerId}";

        // One-time migration banner shown to every player whose visibility
        // was migrated by Sprint 0 S0.5's heal pass. Dismiss is persisted
        // via HandleDismissMigrationBannerAsync below.
        _showMigrationBanner = !_player.MigrationBannerDismissed;
    }

    private async Task HandleDismissMigrationBannerAsync()
    {
        if (_playerId is null || _player is null) return;

        _player.MigrationBannerDismissed = true;
        await PlayerRepository.UpdateAsync(_player);
        _showMigrationBanner = false;

        // Reload the page so the banner stays hidden on the next render.
        Navigation.NavigateTo("/players/me/edit");
    }

    private async Task HandleSubmitAsync()
    {
        if (_playerId is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        _isSaving = true;
        _errorMessage = "";

        try
        {
            var visibility = new ProfileVisibility
            {
                EmailAudience    = _model.EmailAudience,
                PhoneAudience    = _model.PhoneAudience,
                RealNameAudience = _model.RealNameAudience,
                AvatarAudience   = _model.AvatarAudience,
            };

            var update = new PlayerProfileUpdate(
                DisplayName: _model.DisplayName,
                EmailAddress: null,          // email changes not supported in v1
                PhoneNumber: _model.PhoneNumber,
                FirstName: _model.FirstName,
                MiddleName: _model.MiddleName,
                LastName: _model.LastName,
                Visibility: visibility);

            await PlayerService.UpdateProfileAsync(_playerId.Value, update);
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to save profile. Please try again.";
            Logger.LogWarning(ex, "Failed to update profile for player {PlayerId}.", _playerId);
            _isSaving = false;
            return;
        }

        // NavigateTo from a static-SSR form handler throws NavigationException as the
        // signal-to-redirect mechanism. It MUST escape this method uncaught so Blazor's
        // infrastructure can convert it into a 302 redirect. Calling it AFTER the catch
        // block (not inside a try/catch) ensures that happens correctly.
        // See: DEF-001 pattern — never wrap NavigateTo in a catch (Exception) block.
        Navigation.NavigateTo($"/players/{_playerId.Value}");
    }

    // ── Form model ───────────────────────────────────────────────────────────

    private sealed class EditProfileModel
    {
        [Required(ErrorMessage = "Display name is required.")]
        [StringLength(32, MinimumLength = 2,
            ErrorMessage = "Display name must be between 2 and 32 characters.")]
        [RegularExpression(@"^[a-zA-Z0-9_\-]+$",
            ErrorMessage = "Display name may only contain letters, digits, underscores, and hyphens.")]
        public string DisplayName { get; set; } = "";

        [StringLength(50)] public string? FirstName   { get; set; }
        [StringLength(50)] public string? MiddleName  { get; set; }
        [StringLength(50)] public string? LastName    { get; set; }
        [StringLength(30)] public string? PhoneNumber { get; set; }

        public Audience EmailAudience    { get; set; } = Audience.Private;
        public Audience PhoneAudience    { get; set; } = Audience.Private;
        public Audience RealNameAudience { get; set; } = Audience.Private;
        public Audience AvatarAudience   { get; set; } = Audience.Public;

        public static EditProfileModel From(Player p) => new()
        {
            DisplayName      = p.DisplayName,
            FirstName        = p.FirstName,
            MiddleName       = p.MiddleName,
            LastName         = p.LastName,
            PhoneNumber      = p.PhoneNumber,
            EmailAudience    = p.Visibility.EmailAudience,
            PhoneAudience    = p.Visibility.PhoneAudience,
            RealNameAudience = p.Visibility.RealNameAudience,
            AvatarAudience   = p.Visibility.AvatarAudience,
        };
    }
}
