@page "/players/{PlayerId:guid}"
@page "/players/me"
@* "/players/me" is the authenticated-viewer shortcut — PlayerId is
   resolved from the ClaimNames.PlayerId claim in OnInitialized. Both
   UserMenu and NavMenu link to this literal route. See docs/defects.md
   DEF-002. *@
@inject IPlayerService PlayerService
@inject IStatisticsService StatisticsService
@inject IGameRepository GameRepository
@inject IVenueService VenueService
@inject ICommunityService CommunityService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject ILogger<Profile> Logger
@using System.ComponentModel.DataAnnotations
@using NinetyNine.Services.Models

<PageTitle>
    @(_profile is not null ? $"{_profile.DisplayName} \u2014 NinetyNine" : "Player Profile \u2014 NinetyNine")
</PageTitle>

<div class="nn-page nn-profile-page">

    @if (_loading)
    {
        <div class="nn-profile-page__loading" aria-live="polite" aria-busy="true">
            <span class="spinner-border spinner-border-sm me-2"
                  role="status"
                  aria-hidden="true"></span>
            Loading&hellip;
        </div>
    }
    else if (_profile is null)
    {
        <div class="nn-profile-page__not-found">
            <h1 class="nn-profile-page__not-found-title">Player not found</h1>
            <p class="nn-profile-page__not-found-body">
                This player does not exist or their profile is unavailable.
            </p>
            <a href="/stats" class="btn btn-outline-secondary">Back to leaderboard</a>
        </div>
    }
    else if (_profile.IsRetired)
    {
        <div class="nn-profile-page__not-found">
            <h1 class="nn-profile-page__not-found-title">@_profile.DisplayName</h1>
            <p class="nn-profile-page__not-found-body">
                This player is no longer active. Their game history is preserved.
            </p>
            <a href="/stats" class="btn btn-outline-secondary">Back to leaderboard</a>
        </div>
    }
    else
    {
        @* ── 1. Profile header card ────────────────────────────────────── *@
        <section class="nn-profile-page__card nn-profile-page__header-card"
                 aria-label="Player profile">
            <div class="nn-profile-page__header-avatar">
                @if (_profile.Avatar is not null)
                {
                    <AvatarImage AvatarUrl="@_avatarUrl"
                                 DisplayName="@_profile.DisplayName"
                                 SizePx="96" />
                }
                else
                {
                    <InitialsAvatar DisplayName="@_profile.DisplayName" SizePx="96" />
                }
            </div>

            <div class="nn-profile-page__header-info">
                <h1 class="nn-profile-page__display-name">@_profile.DisplayName</h1>

                @if (_profile.HasRealName)
                {
                    <p class="nn-profile-page__real-name">
                        @string.Join(" ", new[]
                        {
                            _profile.FirstName,
                            _profile.MiddleName,
                            _profile.LastName
                        }.Where(s => !string.IsNullOrWhiteSpace(s)))
                    </p>
                }

                <p class="nn-profile-page__member-since">
                    Member since
                    <time datetime="@_profile.CreatedAt.ToString("O")">
                        @_profile.CreatedAt.ToString("MMM yyyy")
                    </time>
                </p>

                @if (_profile.IsOwnProfile)
                {
                    <a href="/players/me/edit"
                       class="btn btn-outline-primary btn-sm nn-profile-page__edit-btn">
                        Edit profile
                    </a>
                }
            </div>
        </section>

        @* ── 2. Contact info card (only populated gated fields) ────────── *@
        @if (!_profile.IsOwnProfile
             && (!string.IsNullOrWhiteSpace(_profile.EmailAddress)
                 || !string.IsNullOrWhiteSpace(_profile.PhoneNumber)))
        {
            <section class="nn-profile-page__card nn-profile-page__contact-card"
                     aria-label="Contact information">
                <h2 class="nn-profile-page__card-title">Contact</h2>

                <dl class="nn-profile-page__contact-list">
                    @if (!string.IsNullOrWhiteSpace(_profile.EmailAddress))
                    {
                        <div class="nn-profile-page__contact-row">
                            <dt class="nn-profile-page__contact-label">Email</dt>
                            <dd class="nn-profile-page__contact-value">
                                <a href="mailto:@_profile.EmailAddress">@_profile.EmailAddress</a>
                            </dd>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_profile.PhoneNumber))
                    {
                        <div class="nn-profile-page__contact-row">
                            <dt class="nn-profile-page__contact-label">Phone</dt>
                            <dd class="nn-profile-page__contact-value">
                                <a href="tel:@_profile.PhoneNumber">@_profile.PhoneNumber</a>
                            </dd>
                        </div>
                    }
                </dl>
            </section>
        }

        @* ── 3. Stats summary card ─────────────────────────────────────── *@
        <section class="nn-profile-page__card nn-profile-page__stats-card"
                 aria-label="Player statistics">
            <h2 class="nn-profile-page__card-title">Statistics</h2>

            @if (_stats is null)
            {
                <p class="nn-profile-page__stats-empty">No statistics available.</p>
            }
            else
            {
                <div class="nn-profile-page__stats-grid">
                    <div class="nn-profile-page__stat">
                        <span class="nn-profile-page__stat-value">@_stats.GamesPlayed</span>
                        <span class="nn-profile-page__stat-label">Games played</span>
                    </div>
                    <div class="nn-profile-page__stat">
                        <span class="nn-profile-page__stat-value">@_stats.GamesCompleted</span>
                        <span class="nn-profile-page__stat-label">Completed</span>
                    </div>
                    <div class="nn-profile-page__stat">
                        <span class="nn-profile-page__stat-value font-monospace @(_stats.BestScore == 99 ? "nn-profile-page__stat-value--perfect" : "")">
                            @_stats.BestScore
                        </span>
                        <span class="nn-profile-page__stat-label">Best score</span>
                    </div>
                    <div class="nn-profile-page__stat">
                        <span class="nn-profile-page__stat-value font-monospace">@_stats.AverageScore.ToString("F1")</span>
                        <span class="nn-profile-page__stat-label">Avg score</span>
                    </div>
                    <div class="nn-profile-page__stat">
                        <span class="nn-profile-page__stat-value">@_stats.PerfectGames</span>
                        <span class="nn-profile-page__stat-label">Perfect games</span>
                    </div>
                    <div class="nn-profile-page__stat">
                        <span class="nn-profile-page__stat-value">@_stats.PerfectFrames</span>
                        <span class="nn-profile-page__stat-label">Perfect frames</span>
                    </div>
                    @if (_stats.LastPlayed.HasValue)
                    {
                        <div class="nn-profile-page__stat nn-profile-page__stat--wide">
                            <span class="nn-profile-page__stat-value">@RelativeTime(_stats.LastPlayed.Value)</span>
                            <span class="nn-profile-page__stat-label">Last played</span>
                        </div>
                    }
                </div>
            }
        </section>

        @* ── 3b. Communities card (Sprint 2 S2.5) ────────────────────────
           Shows the target player's communities. For privacy, the service
           layer is responsible for filtering — but since ICommunityService
           currently has no viewer-scoped "which of this player's communities
           can I see" query, the page does the filtering inline:
             * Always include communities where the viewer is also a member.
             * Include public communities the target belongs to.
             * Exclude private communities where the viewer is not a member
               (never reveal private community membership).
           A v1.2 refactor will fold this into IPlayerService.GetProfileForViewerAsync. *@
        @if (_visibleCommunities.Count > 0)
        {
            <section class="nn-profile-page__card nn-profile-page__communities-card"
                     aria-label="Communities">
                <h2 class="nn-profile-page__card-title">Communities</h2>
                <ul class="nn-profile-page__communities-list" role="list">
                    @foreach (var c in _visibleCommunities)
                    {
                        <li class="nn-profile-page__community-row" role="listitem">
                            <a href="/communities/@c.CommunityId"
                               class="nn-profile-page__community-link">
                                <span class="nn-profile-page__community-name">@c.Name</span>
                                @if (c.Visibility == CommunityVisibility.Private)
                                {
                                    <span class="nn-profile-page__community-pill">Private</span>
                                }
                            </a>
                        </li>
                    }
                </ul>
            </section>
        }

        @* ── 4. Recent games card ──────────────────────────────────────── *@
        <section class="nn-profile-page__card nn-profile-page__games-card"
                 aria-label="Recent games">
            <h2 class="nn-profile-page__card-title">Recent games</h2>

            @if (_recentGames.Count == 0)
            {
                <p class="nn-profile-page__games-empty">No games yet.</p>
            }
            else
            {
                <ul class="nn-profile-page__games-list" role="list">
                    @foreach (var game in _recentGames)
                    {
                        var href = game.IsInProgress && _profile.IsOwnProfile
                            ? $"/games/{game.GameId}/play"
                            : $"/games/{game.GameId}";

                        var venueIsMasked = _maskedVenueIds.Contains(game.VenueId);
                        var venueLabel = venueIsMasked
                            ? "Private venue"
                            : (_venueNames.TryGetValue(game.VenueId, out var vn) ? vn : "\u2014");

                        <li class="nn-profile-page__game-row" role="listitem">
                            <a href="@href"
                               class="nn-profile-page__game-link"
                               aria-label="@GameRowAriaLabel(game, venueLabel)">

                                <time class="nn-profile-page__game-date"
                                      datetime="@game.WhenPlayed.ToString("O")"
                                      title="@game.WhenPlayed.ToLocalTime().ToString("f")">
                                    @game.WhenPlayed.ToLocalTime().ToString("MMM d, yyyy")
                                </time>

                                <span class="nn-profile-page__game-venue @(venueIsMasked ? "nn-profile-page__game-venue--masked" : null)">
                                    @venueLabel
                                </span>

                                <span class="nn-profile-page__game-score font-monospace">
                                    @game.TotalScore<span class="nn-profile-page__game-score-max">/99</span>
                                    @if (game.IsPerfectGame)
                                    {
                                        <span class="nn-profile-page__perfect-badge ms-1"
                                              aria-label="Perfect game">99!</span>
                                    }
                                </span>

                                <span class="nn-status-pill @StatusPillClass(game.GameState)">
                                    @StatusLabel(game.GameState)
                                </span>
                            </a>
                        </li>
                    }
                </ul>
            }
        </section>
    }

</div>

@code {
    [Parameter] public Guid PlayerId { get; set; }

    private ViewerScopedPlayerProfile? _profile;
    private PlayerStats? _stats;
    private string? _avatarUrl;
    private List<Game> _recentGames = [];
    private Dictionary<Guid, string> _venueNames = new();
    private HashSet<Guid> _maskedVenueIds = new();
    private List<Community> _visibleCommunities = [];
    private bool _loading = true;
    private Guid? _viewerId;

    protected override void OnInitialized()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        var claim = user?.FindFirst(ClaimNames.PlayerId)?.Value;
        Guid.TryParse(claim, out var viewerId);

        // Route "/players/me" omits the PlayerId route parameter, so it
        // arrives as Guid.Empty. Resolve from claims; redirect to login
        // if the viewer is not authenticated.
        if (PlayerId == Guid.Empty)
        {
            if (viewerId == Guid.Empty)
            {
                Navigation.NavigateTo("/login?ReturnUrl=/players/me", forceLoad: true);
                return;
            }
            PlayerId = viewerId;
        }

        _viewerId = viewerId == Guid.Empty ? null : viewerId;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _profile = await PlayerService.GetProfileForViewerAsync(PlayerId, _viewerId);

            if (_profile is null)
            {
                _loading = false;
                return;
            }

            if (_profile.Avatar is not null)
                _avatarUrl = $"/api/avatars/{_profile.PlayerId}";

            // Load stats — best-effort; page still renders without them
            try
            {
                _stats = await StatisticsService.GetPlayerStatsAsync(PlayerId);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to load stats for player {PlayerId}.", PlayerId);
            }

            // Load recent games + resolve venue names, masking private
            // venues the viewer is not the creator of (plan S3.6).
            try
            {
                var games = await GameRepository.GetByPlayerAsync(PlayerId, skip: 0, limit: 5);
                _recentGames = games.OrderByDescending(g => g.WhenPlayed).ToList();

                var uniqueVenueIds = _recentGames.Select(g => g.VenueId).Distinct();
                foreach (var venueId in uniqueVenueIds)
                {
                    try
                    {
                        var venue = await VenueService.GetAsync(venueId);
                        if (venue is null) continue;

                        // Private venues are visible only to their creator.
                        // For every other viewer (including the target when
                        // viewing their own profile but not the creator, and
                        // any non-creator viewer), mask the venue's name and
                        // drop the link.
                        var viewerIsCreator = _viewerId is not null
                            && venue.CreatedByPlayerId == _viewerId.Value;
                        if (venue.Private && !viewerIsCreator)
                        {
                            _maskedVenueIds.Add(venueId);
                        }
                        else
                        {
                            _venueNames[venueId] = venue.Name;
                        }
                    }
                    catch (Exception ex)
                    {
                        Logger.LogWarning(ex, "Could not resolve venue {VenueId}.", venueId);
                    }
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to load recent games for player {PlayerId}.", PlayerId);
            }

            // Communities section (Sprint 2 S2.5). Privacy filter:
            //   * Own profile: all communities the target belongs to.
            //   * Other viewer: public communities the target belongs to,
            //     plus any private community where the viewer is also a
            //     member. Never reveal private community membership to
            //     non-members.
            try
            {
                var all = await CommunityService.ListCommunitiesForPlayerAsync(PlayerId);
                if (_profile.IsOwnProfile)
                {
                    _visibleCommunities = all.ToList();
                }
                else
                {
                    var filtered = new List<Community>();
                    foreach (var c in all)
                    {
                        if (c.Visibility == CommunityVisibility.Public)
                        {
                            filtered.Add(c);
                            continue;
                        }
                        if (_viewerId is not null
                            && await CommunityService.IsMemberAsync(c.CommunityId, _viewerId.Value))
                        {
                            filtered.Add(c);
                        }
                    }
                    _visibleCommunities = filtered;
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to load communities for player {PlayerId}.", PlayerId);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load public profile for player {PlayerId}.", PlayerId);
            _profile = null;
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Display helpers ─────────────────────────────────────────────────

    private static string RelativeTime(DateTime utc)
    {
        var diff = DateTime.UtcNow - utc;

        return diff.TotalSeconds < 60      ? "Just now"
             : diff.TotalMinutes < 60      ? $"{(int)diff.TotalMinutes}m ago"
             : diff.TotalHours < 24        ? $"{(int)diff.TotalHours}h ago"
             : diff.TotalDays < 2          ? "Yesterday"
             : diff.TotalDays < 7          ? $"{(int)diff.TotalDays} days ago"
             : diff.TotalDays < 30         ? $"{(int)(diff.TotalDays / 7)} weeks ago"
             : diff.TotalDays < 365        ? $"{(int)(diff.TotalDays / 30)} months ago"
             : $"{(int)(diff.TotalDays / 365)} years ago";
    }

    private static string StatusLabel(GameState state) => state switch
    {
        GameState.Completed  => "Completed",
        GameState.InProgress => "In progress",
        GameState.Paused     => "Paused",
        _                    => "Not started"
    };

    private static string StatusPillClass(GameState state) => state switch
    {
        GameState.Completed  => "nn-status-pill--completed",
        GameState.InProgress => "nn-status-pill--inprogress",
        GameState.Paused     => "nn-status-pill--paused",
        _                    => "nn-status-pill--muted"
    };

    private static string GameRowAriaLabel(Game game, string venueLabel)
    {
        return $"{StatusLabel(game.GameState)} game at {venueLabel} on "
             + $"{game.WhenPlayed.ToLocalTime():MMM d, yyyy}, score {game.TotalScore} out of 99";
    }
}
