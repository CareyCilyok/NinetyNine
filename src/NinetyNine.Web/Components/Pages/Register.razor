@page "/register"
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILogger<Register> Logger
@using System.ComponentModel.DataAnnotations
@using NinetyNine.Services.Auth

<PageTitle>Create account &mdash; NinetyNine</PageTitle>

<div class="nn-page nn-auth-page">
    <div class="nn-auth-card">
        <div class="nn-auth-card__wordmark" aria-hidden="true">NinetyNine</div>
        <h1 class="nn-auth-card__title">Create your NinetyNine account</h1>
        <p class="nn-auth-card__subtitle">
            Track your Ninety-Nine runs and see how you stack up.
        </p>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger" role="alert">@_errorMessage</div>
        }

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="alert alert-success" role="alert">
                @_successMessage
                <div class="mt-2">
                    <a href="/login" class="alert-link">Back to sign in</a>
                </div>
            </div>
        }
        else
        {
            <EditForm Model="_model" method="post" OnValidSubmit="HandleSubmitAsync" FormName="register">
                @* AntiforgeryToken auto-injected by Blazor SSR form handler.
                   See docs/defects.md DEF-003. *@
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label class="form-label" for="email">Email address</label>
                    <InputText id="email" type="email"
                               class="form-control"
                               @bind-Value="_model.Email"
                               autocomplete="email" required
                               aria-describedby="email-hint" />
                    <ValidationMessage For="() => _model.Email" />
                </div>

                <div class="form-group">
                    <label class="form-label" for="display-name">Display name</label>
                    <InputText id="display-name"
                               class="form-control"
                               @bind-Value="_model.DisplayName"
                               autocomplete="username" required
                               aria-describedby="display-name-hint" />
                    <div id="display-name-hint" class="form-text">2&ndash;32 characters. Letters, numbers, _ and - only.</div>
                    <ValidationMessage For="() => _model.DisplayName" />
                </div>

                <div class="form-group">
                    <label class="form-label" for="password">Password</label>
                    <InputText id="password" type="password"
                               class="form-control"
                               @bind-Value="_model.Password"
                               autocomplete="new-password" required
                               aria-describedby="password-hint" />
                    <div id="password-hint" class="form-text">
                        At least 10 characters with uppercase, lowercase, digit, and symbol.
                    </div>
                    <ValidationMessage For="() => _model.Password" />
                </div>

                <div class="form-group">
                    <label class="form-label" for="confirm-password">Confirm password</label>
                    <InputText id="confirm-password" type="password"
                               class="form-control"
                               @bind-Value="_model.ConfirmPassword"
                               autocomplete="new-password" required />
                    <ValidationMessage For="() => _model.ConfirmPassword" />
                </div>

                <button type="submit" class="btn btn-primary w-100" disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <span>Creating account&hellip;</span>
                    }
                    else
                    {
                        <span>Create account</span>
                    }
                </button>
            </EditForm>

            <p class="nn-auth-card__aside">
                Already have an account? <a href="/login">Sign in</a>.
            </p>
        }
    </div>
</div>

@code {
    [SupplyParameterFromForm(FormName = "register")]
    private RegisterModel _model { get; set; } = new();

    private string _errorMessage = "";
    private string _successMessage = "";
    private bool _isSubmitting;

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = "";

        try
        {
            var verifyUrlBase = Navigation.BaseUri.TrimEnd('/');

            var result = await AuthService.RegisterAsync(
                _model.Email,
                _model.DisplayName,
                _model.Password,
                _model.ConfirmPassword,
                verifyUrlBase);

            if (result.Success)
            {
                _successMessage = "Account created. Check your email to verify your account before signing in.";
            }
            else
            {
                _errorMessage = result.ErrorMessage ?? "Registration failed. Please try again.";
                Logger.LogInformation("Registration failed for {Email}: {Error}", _model.Email, result.ErrorMessage);
            }
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private sealed class RegisterModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Display name is required.")]
        [StringLength(32, MinimumLength = 2, ErrorMessage = "Display name must be 2-32 characters.")]
        [RegularExpression(@"^[a-zA-Z0-9_-]+$", ErrorMessage = "Only letters, numbers, underscores, and hyphens.")]
        public string DisplayName { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [StringLength(128, MinimumLength = 10, ErrorMessage = "Password must be at least 10 characters.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
