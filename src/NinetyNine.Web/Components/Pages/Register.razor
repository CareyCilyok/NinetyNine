@page "/register"
@implements IDisposable
@inject IPlayerService PlayerService
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor
@inject ILogger<Register> Logger
@using NinetyNine.Services

<PageTitle>Create Profile &mdash; NinetyNine</PageTitle>

<div class="row justify-content-center mt-4">
    <div class="col-md-7 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 card-title mb-1">Create Your Profile</h1>
                <p class="text-muted mb-4">
                    Choose a display name to get started. All other fields are optional.
                </p>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger" role="alert">@_errorMessage</div>
                }

                @if (!_hasRegistrationCookie)
                {
                    <div class="alert alert-warning" role="alert">
                        No pending registration found. Please <a href="/login">sign in</a> first.
                    </div>
                }
                else
                {
                    <EditForm Model="_model" OnValidSubmit="HandleRegister">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="display-name">
                                Display Name <span class="text-danger" aria-hidden="true">*</span>
                            </label>
                            <div class="input-group">
                                <InputText id="display-name"
                                           class="@DisplayNameCssClass"
                                           @bind-Value="_model.DisplayName"
                                           @oninput="OnDisplayNameInput"
                                           placeholder="e.g. sharky_mike"
                                           autocomplete="username"
                                           aria-describedby="display-name-feedback" />
                                @if (_checkingName)
                                {
                                    <span class="input-group-text">
                                        <span class="spinner-border spinner-border-sm" role="status" aria-label="Checking availability"></span>
                                    </span>
                                }
                            </div>
                            <div id="display-name-feedback" class="form-text">
                                2–32 characters, letters, numbers, _ and - only.
                                @if (_displayNameAvailable == true)
                                {
                                    <span class="text-success">Available!</span>
                                }
                                else if (_displayNameAvailable == false)
                                {
                                    <span class="text-danger">That name is taken.</span>
                                }
                            </div>
                            <ValidationMessage For="() => _model.DisplayName" />
                        </div>

                        <hr class="my-3" />
                        <p class="text-muted small">
                            Optional information — all hidden by default. Use the toggles to make fields public.
                        </p>

                        <div class="mb-3 d-flex gap-2 align-items-start">
                            <div class="flex-grow-1">
                                <label class="form-label" for="first-name">First Name</label>
                                <InputText id="first-name" class="form-control"
                                           @bind-Value="_model.FirstName"
                                           autocomplete="given-name" />
                            </div>
                        </div>

                        <div class="mb-3 d-flex gap-2 align-items-start">
                            <div class="flex-grow-1">
                                <label class="form-label" for="last-name">Last Name</label>
                                <InputText id="last-name" class="form-control"
                                           @bind-Value="_model.LastName"
                                           autocomplete="family-name" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="email">Email</label>
                            <InputText id="email" class="form-control"
                                       @bind-Value="_model.EmailAddress"
                                       autocomplete="email"
                                       inputmode="email" />
                        </div>

                        <div class="mb-4">
                            <VisibilityToggle Label="Show real name publicly"
                                              @bind-Value="_model.ShowRealName" />
                            <VisibilityToggle Label="Show email publicly"
                                              @bind-Value="_model.ShowEmail" />
                        </div>

                        <button type="submit"
                                class="btn btn-primary w-100"
                                disabled="@(_isSaving || _displayNameAvailable == false)">
                            @if (_isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Creating profile&hellip;</span>
                            }
                            else
                            {
                                <span>Create Profile</span>
                            }
                        </button>
                    </EditForm>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string DisplayNameCssClass => _displayNameAvailable switch
    {
        true => "form-control is-valid",
        false => "form-control is-invalid",
        _ => "form-control"
    };

    private RegisterModel _model = new();
    private string _errorMessage = "";
    private bool _hasRegistrationCookie;
    private string _provider = "";
    private string _providerUserId = "";
    private bool? _displayNameAvailable;
    private bool _checkingName;
    private bool _isSaving;
    private System.Timers.Timer? _debounceTimer;

    protected override void OnInitialized()
    {
        var context = HttpContextAccessor.HttpContext;
        if (context is null) return;

        var cookie = ExternalLoginHandler.ReadTempRegistrationCookie(context.Request.Cookies);
        if (cookie is not null)
        {
            _hasRegistrationCookie = true;
            _provider = cookie.Value.Provider;
            _providerUserId = cookie.Value.ProviderUserId;
        }
    }

    private void OnDisplayNameInput(ChangeEventArgs e)
    {
        _model.DisplayName = e.Value?.ToString() ?? "";
        _displayNameAvailable = null;
        _debounceTimer?.Dispose();

        if (_model.DisplayName.Length >= 2)
        {
            _debounceTimer = new System.Timers.Timer(400);
            _debounceTimer.Elapsed += async (_, _) =>
            {
                _debounceTimer?.Dispose();
                await InvokeAsync(CheckDisplayNameAsync);
            };
            _debounceTimer.AutoReset = false;
            _debounceTimer.Start();
        }
    }

    private async Task CheckDisplayNameAsync()
    {
        _checkingName = true;
        StateHasChanged();
        try
        {
            _displayNameAvailable = await PlayerService.IsDisplayNameAvailableAsync(_model.DisplayName);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to check display name availability.");
        }
        finally
        {
            _checkingName = false;
            StateHasChanged();
        }
    }

    private async Task HandleRegister()
    {
        if (!_hasRegistrationCookie)
        {
            _errorMessage = "Registration session expired. Please sign in again.";
            return;
        }

        _isSaving = true;
        _errorMessage = "";

        try
        {
            var player = await PlayerService.RegisterAsync(
                _model.DisplayName,
                _provider,
                _providerUserId);

            // Apply optional profile update
            var hasOptional = _model.FirstName is not null
                || _model.LastName is not null
                || _model.EmailAddress is not null;

            if (hasOptional)
            {
                var update = new PlayerProfileUpdate(
                    DisplayName: null,
                    EmailAddress: _model.EmailAddress,
                    PhoneNumber: null,
                    FirstName: _model.FirstName,
                    MiddleName: null,
                    LastName: _model.LastName,
                    Visibility: new ProfileVisibility
                    {
                        RealName = _model.ShowRealName,
                        EmailAddress = _model.ShowEmail,
                        Avatar = true
                    });

                await PlayerService.UpdateProfileAsync(player.PlayerId, update);
            }

            // Clear temp cookie and redirect to sign-in.
            // For OAuth providers we bounce through /login to re-run the external
            // handshake (provider session still live). For mock mode we sign the
            // user in directly via the mock endpoint.
            var context = HttpContextAccessor.HttpContext;
            if (context is not null)
                ExternalLoginHandler.ClearTempRegistrationCookie(context.Response);

            if (_provider == IDataSeeder.MockProvider)
                Navigation.NavigateTo($"/mock/signin-as?playerId={player.PlayerId}", forceLoad: true);
            else
                Navigation.NavigateTo("/login", forceLoad: true);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            Logger.LogWarning(ex, "Registration failed for display name {DisplayName}.", _model.DisplayName);
        }
        finally
        {
            _isSaving = false;
        }
    }

    public void Dispose() => _debounceTimer?.Dispose();

    private sealed class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Display name is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(32, MinimumLength = 2, ErrorMessage = "Display name must be 2–32 characters.")]
        [System.ComponentModel.DataAnnotations.RegularExpression(@"^[a-zA-Z0-9_-]+$", ErrorMessage = "Only letters, numbers, underscores, and hyphens allowed.")]
        public string DisplayName { get; set; } = "";

        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? EmailAddress { get; set; }
        public bool ShowRealName { get; set; }
        public bool ShowEmail { get; set; }
    }
}
