@page "/resend-verification"
@using System.ComponentModel.DataAnnotations
@using NinetyNine.Services.Auth
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILogger<ResendVerification> Logger

<PageTitle>Resend verification email &mdash; NinetyNine</PageTitle>

<div class="nn-page nn-auth-page">
    <div class="nn-auth-card">
        <div class="nn-auth-card__wordmark" aria-hidden="true">NinetyNine</div>
        <h1 class="nn-auth-card__title">Resend verification email</h1>
        <p class="nn-auth-card__subtitle">
            Enter the email address you registered with and we will send a new verification link.
        </p>

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="alert alert-success" role="alert">@_successMessage</div>
        }

        @if (!_submitted)
        {
            <EditForm Model="_model" method="post" OnValidSubmit="HandleSubmitAsync" FormName="resend-verification">
                <AntiforgeryToken />
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label class="form-label" for="email">Email address</label>
                    <InputText id="email" type="email"
                               class="form-control"
                               @bind-Value="_model.Email"
                               autocomplete="email" required />
                    <ValidationMessage For="() => _model.Email" />
                </div>

                <button type="submit" class="btn btn-primary w-100" disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <span>Sending&hellip;</span>
                    }
                    else
                    {
                        <span>Resend verification email</span>
                    }
                </button>
            </EditForm>
        }

        <p class="nn-auth-card__aside">
            <a href="/login">Back to sign in</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromForm(FormName = "resend-verification")]
    private ResendVerificationModel _model { get; set; } = new();

    private string _successMessage = "";
    private bool _isSubmitting;
    private bool _submitted;

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;

        try
        {
            var verifyUrlBase = new Uri(Navigation.BaseUri).GetLeftPart(UriPartial.Authority);
            await AuthService.ResendVerificationAsync(_model.Email, verifyUrlBase);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error during resend-verification request.");
        }
        finally
        {
            // Always show the generic message regardless of outcome — no enumeration.
            _submitted = true;
            _isSubmitting = false;
            _successMessage = "If an unverified account with that email exists, a new verification link has been sent. Check your inbox.";
        }
    }

    private sealed class ResendVerificationModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";
    }
}
