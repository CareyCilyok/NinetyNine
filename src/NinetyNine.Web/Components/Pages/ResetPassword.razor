@page "/reset-password"
@using System.ComponentModel.DataAnnotations
@using NinetyNine.Services.Auth
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILogger<ResetPassword> Logger

<PageTitle>Reset password &mdash; NinetyNine</PageTitle>

<div class="nn-page nn-auth-page">
    <div class="nn-auth-card">
        <div class="nn-auth-card__wordmark" aria-hidden="true">NinetyNine</div>
        <h1 class="nn-auth-card__title">Set a new password</h1>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger" role="alert">
                @_errorMessage
                @if (_showForgotLink)
                {
                    <div class="mt-2">
                        <a href="/forgot-password" class="alert-link">Request a new reset link</a>
                    </div>
                }
            </div>
        }
        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="alert alert-success" role="alert">@_successMessage</div>
        }

        @if (string.IsNullOrWhiteSpace(Token))
        {
            <div class="alert alert-danger" role="alert">
                Invalid or missing reset token. Please
                <a href="/forgot-password" class="alert-link">request a new password reset link</a>.
            </div>
        }
        else if (!_submitted)
        {
            <EditForm Model="_model" method="post" OnValidSubmit="HandleSubmitAsync" FormName="reset-password">
                @* AntiforgeryToken auto-injected by Blazor SSR form handler.
                   See docs/defects.md DEF-003. *@
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label class="form-label" for="new-password">New password</label>
                    <InputText id="new-password" type="password"
                               class="form-control"
                               @bind-Value="_model.NewPassword"
                               autocomplete="new-password" required
                               aria-describedby="new-password-hint" />
                    <div id="new-password-hint" class="form-text">
                        At least 10 characters with uppercase, lowercase, digit, and symbol (!&#64;#$%^&amp;*).
                    </div>
                    <ValidationMessage For="() => _model.NewPassword" />
                </div>

                <div class="form-group">
                    <label class="form-label" for="confirm-password">Confirm new password</label>
                    <InputText id="confirm-password" type="password"
                               class="form-control"
                               @bind-Value="_model.ConfirmPassword"
                               autocomplete="new-password" required />
                    <ValidationMessage For="() => _model.ConfirmPassword" />
                </div>

                <button type="submit" class="btn btn-primary w-100" disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <span>Saving&hellip;</span>
                    }
                    else
                    {
                        <span>Set new password</span>
                    }
                </button>
            </EditForm>
        }

        <p class="nn-auth-card__aside">
            <a href="/login">Back to sign in</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }

    [SupplyParameterFromForm(FormName = "reset-password")]
    private ResetPasswordModel _model { get; set; } = new();

    private string _errorMessage = "";
    private string _successMessage = "";
    private bool _isSubmitting;
    private bool _submitted;
    private bool _showForgotLink;

    private async Task HandleSubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            _errorMessage = "Invalid or missing reset token. Please request a new password reset link.";
            _showForgotLink = true;
            return;
        }

        _isSubmitting = true;
        _errorMessage = "";
        _showForgotLink = false;

        try
        {
            var result = await AuthService.ResetPasswordAsync(Token, _model.NewPassword, _model.ConfirmPassword);

            if (result.Success)
            {
                _submitted = true;
                _successMessage = "Password reset successful. Redirecting to sign in\u2026";
                _ = Task.Run(async () =>
                {
                    await Task.Delay(2000);
                    await InvokeAsync(() => Navigation.NavigateTo("/login", forceLoad: false));
                });
            }
            else
            {
                var error = result.ErrorMessage ?? "Password reset failed. Please try again.";
                _errorMessage = error;

                // Expired or invalid token — guide the user to request a new one.
                if (error.Contains("invalid", StringComparison.OrdinalIgnoreCase)
                    || error.Contains("expired", StringComparison.OrdinalIgnoreCase))
                {
                    _showForgotLink = true;
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error during password reset.");
            _errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private sealed class ResetPasswordModel
    {
        [Required(ErrorMessage = "Password is required.")]
        [StringLength(128, MinimumLength = 10, ErrorMessage = "Password must be at least 10 characters.")]
        public string NewPassword { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
