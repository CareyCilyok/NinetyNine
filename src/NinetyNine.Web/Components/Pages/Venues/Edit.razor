@page "/venues/new"
@page "/venues/{VenueId:guid}/edit"
@attribute [Authorize]
@inject IVenueService VenueService
@inject ICommunityService CommunityService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject ILogger<Edit> Logger
@using System.ComponentModel.DataAnnotations

<PageTitle>@(_isNew ? "Add Venue" : "Edit Venue") &mdash; NinetyNine</PageTitle>

<div class="nn-page nn-venue-edit">
    <div class="nn-venue-edit__inner">

        <header class="nn-venue-edit__header">
            <h1 class="nn-venue-edit__title">@(_isNew ? "Add Venue" : "Edit Venue")</h1>
        </header>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger" role="alert">@_errorMessage</div>
        }

        @if (_loading)
        {
            <div class="nn-venue-edit__loading" role="status" aria-live="polite">
                <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                Loading&hellip;
            </div>
        }
        else if (_notFound)
        {
            <div class="nn-empty-state" role="status">
                <p class="nn-empty-state__title">Venue not found</p>
                <p class="nn-empty-state__description">
                    The venue you are looking for does not exist or has been deleted.
                </p>
                <a href="/venues" class="btn btn-primary">Back to venues</a>
            </div>
        }
        else
        {
            <div class="nn-venue-edit__form-card">
                <EditForm Model="_saveModel"
                          method="post"
                          FormName="save-venue"
                          OnValidSubmit="HandleSaveAsync">
                    @* AntiforgeryToken auto-injected by Blazor SSR form handler.
                       See docs/defects.md DEF-003. *@
                    <DataAnnotationsValidator />

                    <div class="nn-venue-edit__field">
                        <label class="form-label nn-venue-edit__label" for="venue-name">
                            Name
                            <span class="text-danger" aria-hidden="true">*</span>
                        </label>
                        <InputText id="venue-name"
                                   class="form-control"
                                   @bind-Value="_saveModel.Name"
                                   placeholder="e.g. Corner Pocket"
                                   autocomplete="organization"
                                   aria-required="true" />
                        <ValidationMessage For="() => _saveModel.Name" />
                    </div>

                    <div class="nn-venue-edit__field">
                        <label class="form-label nn-venue-edit__label" for="venue-address">
                            Address
                        </label>
                        <InputText id="venue-address"
                                   class="form-control"
                                   @bind-Value="_saveModel.Address"
                                   placeholder="123 Main St, City, State"
                                   autocomplete="street-address" />
                        <ValidationMessage For="() => _saveModel.Address" />
                    </div>

                    <div class="nn-venue-edit__field">
                        <label class="form-label nn-venue-edit__label" for="venue-phone">
                            Phone number
                        </label>
                        <InputText id="venue-phone"
                                   class="form-control"
                                   @bind-Value="_saveModel.PhoneNumber"
                                   autocomplete="tel"
                                   inputmode="tel" />
                        <ValidationMessage For="() => _saveModel.PhoneNumber" />
                    </div>

                    <div class="nn-venue-edit__field nn-venue-edit__field--check">
                        <div class="form-check form-switch">
                            <InputCheckbox id="venue-private"
                                           class="form-check-input"
                                           @bind-Value="_saveModel.Private"
                                           role="switch"
                                           aria-describedby="venue-private-hint" />
                            <label class="form-check-label" for="venue-private">
                                Private venue
                            </label>
                        </div>
                        <div id="venue-private-hint" class="form-text nn-venue-edit__hint">
                            Private venues only appear in your own venue list and as options when starting a new game.
                        </div>
                    </div>

                    <div class="nn-venue-edit__actions">
                        <button type="submit"
                                class="btn btn-primary nn-venue-edit__submit"
                                disabled="@_isSaving"
                                aria-busy="@_isSaving.ToString().ToLowerInvariant()">
                            @if (_isSaving)
                            {
                                <span class="spinner-border spinner-border-sm"
                                      role="status"
                                      aria-hidden="true"></span>
                                <span>Saving&hellip;</span>
                            }
                            else
                            {
                                <span>@(_isNew ? "Add venue" : "Save changes")</span>
                            }
                        </button>
                        <a href="/venues" class="btn btn-ghost">Cancel</a>
                    </div>
                </EditForm>
            </div>

            @* ── Community affiliation (Sprint 3 S3.2) ───────────────
               Separate form because authorization rules differ: this
               flows through IVenueService.SetCommunityAffiliationAsync
               which enforces "venue creator + current member of target
               community". See docs/plans/friends-communities-v1.md
               Sprint 3 S3.2. *@
            @if (!_isNew)
            {
                <div class="nn-venue-edit__affiliation-section">
                    <h2 class="nn-venue-edit__affiliation-heading">Community affiliation</h2>
                    <p class="nn-venue-edit__affiliation-hint">
                        Affiliate this venue with one of the communities you belong to. Pool
                        players are the only ones who control communities — a venue is
                        affiliated, never owned.
                    </p>

                    @if (!string.IsNullOrEmpty(_affiliationFlashSuccess))
                    {
                        <div class="alert alert-success" role="status">@_affiliationFlashSuccess</div>
                    }
                    @if (!string.IsNullOrEmpty(_affiliationFlashError))
                    {
                        <div class="alert alert-danger" role="alert">@_affiliationFlashError</div>
                    }

                    <EditForm Model="_affiliationModel"
                              method="post"
                              FormName="set-venue-affiliation"
                              OnValidSubmit="HandleAffiliationSaveAsync">
                        @* AntiforgeryToken auto-injected (DEF-003). *@
                        <div class="nn-venue-edit__field">
                            <label class="form-label nn-venue-edit__label" for="venue-community">
                                Community
                            </label>
                            <InputSelect id="venue-community"
                                         class="form-select"
                                         @bind-Value="_affiliationModel.SelectedCommunityId">
                                <option value="">&mdash; None &mdash;</option>
                                @foreach (var c in _myCommunities)
                                {
                                    <option value="@c.CommunityId">@c.Name</option>
                                }
                            </InputSelect>
                            @if (_myCommunities.Count == 0)
                            {
                                <div class="form-text nn-venue-edit__hint">
                                    You are not a member of any community. Create or join one first at <a href="/communities">/communities</a>.
                                </div>
                            }
                        </div>

                        <button type="submit"
                                class="btn btn-primary nn-venue-edit__submit"
                                disabled="@_isSavingAffiliation"
                                aria-busy="@_isSavingAffiliation.ToString().ToLowerInvariant()">
                            @if (_isSavingAffiliation)
                            {
                                <span class="spinner-border spinner-border-sm me-2"
                                      role="status"
                                      aria-hidden="true"></span>
                                <span>Saving&hellip;</span>
                            }
                            else
                            {
                                <span>Save affiliation</span>
                            }
                        </button>
                    </EditForm>
                </div>

                <div class="nn-venue-edit__delete-section">
                    <h2 class="nn-venue-edit__delete-heading">Delete venue</h2>
                    <p class="nn-venue-edit__delete-warning">
                        Deleting this venue is permanent and cannot be undone. Any games
                        recorded at this venue will retain the venue reference but the venue
                        will no longer be selectable for new games.
                    </p>

                    <EditForm Model="_deleteModel"
                              method="post"
                              FormName="delete-venue"
                              OnValidSubmit="HandleDeleteAsync">
                        @* AntiforgeryToken auto-injected by Blazor SSR form handler.
                           See docs/defects.md DEF-003. *@
                        <DataAnnotationsValidator />

                        @* Hidden VenueId carried through the delete form *@
                        <InputText type="hidden" @bind-Value="_deleteModel.VenueId" />

                        <button type="submit"
                                class="btn btn-outline-danger nn-venue-edit__delete-btn"
                                disabled="@_isDeleting"
                                aria-busy="@_isDeleting.ToString().ToLowerInvariant()">
                            @if (_isDeleting)
                            {
                                <span class="spinner-border spinner-border-sm"
                                      role="status"
                                      aria-hidden="true"></span>
                                <span>Deleting&hellip;</span>
                            }
                            else
                            {
                                <img class="nn-icon nn-icon-sm"
                                     src="/icons/phosphor/regular/trash.svg"
                                     alt=""
                                     aria-hidden="true" />
                                <span>Delete venue</span>
                            }
                        </button>
                    </EditForm>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public Guid? VenueId { get; set; }

    [SupplyParameterFromQuery(Name = "flash")]
    public string? Flash { get; set; }

    // ── Save form model ─────────────────────────────────────────────────
    [SupplyParameterFromForm(FormName = "save-venue")]
    private SaveVenueModel _saveModel { get; set; } = new();

    // ── Delete form model ───────────────────────────────────────────────
    [SupplyParameterFromForm(FormName = "delete-venue")]
    private DeleteVenueModel _deleteModel { get; set; } = new();

    // ── Community affiliation form model ────────────────────────────────
    [SupplyParameterFromForm(FormName = "set-venue-affiliation")]
    private AffiliationModel _affiliationModel { get; set; } = new();

    // ── Page state ──────────────────────────────────────────────────────
    private bool _isNew;
    private bool _loading = true;
    private bool _notFound;
    private bool _isSaving;
    private bool _isDeleting;
    private bool _isSavingAffiliation;
    private string _errorMessage = "";
    private string _affiliationFlashSuccess = "";
    private string _affiliationFlashError = "";

    private Guid? _viewerId;
    private List<Community> _myCommunities = [];

    protected override void OnInitialized()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        var claim = user?.FindFirst(ClaimNames.PlayerId)?.Value;
        if (Guid.TryParse(claim, out var id))
            _viewerId = id;

        _affiliationFlashSuccess = Flash switch
        {
            "affiliation-saved" => "Community affiliation updated.",
            _ => "",
        };
    }

    protected override async Task OnInitializedAsync()
    {
        _isNew = VenueId is null;

        if (!_isNew)
        {
            // Pre-populate delete form VenueId
            _deleteModel.VenueId = VenueId!.Value.ToString();

            try
            {
                var venue = await VenueService.GetAsync(VenueId!.Value);
                if (venue is null)
                {
                    _notFound = true;
                }
                else
                {
                    // Only pre-populate the save form if it wasn't already
                    // filled in by a POST round-trip (SupplyParameterFromForm
                    // will have populated it already in that case).
                    if (string.IsNullOrEmpty(_saveModel.Name))
                    {
                        _saveModel.Name        = venue.Name;
                        _saveModel.Address     = venue.Address;
                        _saveModel.PhoneNumber = venue.PhoneNumber;
                        _saveModel.Private     = venue.Private;
                    }

                    // Load communities the viewer is a member of for the
                    // affiliation picker. Pre-select the venue's current
                    // affiliation (or None) unless the user's form post
                    // already populated the field.
                    if (_viewerId is not null)
                    {
                        _myCommunities = (await CommunityService
                            .ListCommunitiesForPlayerAsync(_viewerId.Value)).ToList();

                        if (string.IsNullOrEmpty(_affiliationModel.SelectedCommunityId))
                        {
                            _affiliationModel.SelectedCommunityId =
                                venue.CommunityId?.ToString() ?? "";
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                _errorMessage = "Failed to load venue. Please try again.";
                Logger.LogWarning(ex, "Failed to load venue {VenueId}.", VenueId);
            }
        }

        _loading = false;
    }

    // ── Save handler ────────────────────────────────────────────────────
    private async Task HandleSaveAsync()
    {
        _isSaving = true;
        _errorMessage = "";

        try
        {
            var venue = _saveModel.ToVenue(VenueId ?? Guid.NewGuid());

            if (_isNew)
                await VenueService.CreateAsync(venue);
            else
                await VenueService.UpdateAsync(venue);
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to save the venue. Please try again.";
            Logger.LogWarning(ex, "Failed to save venue.");
            _isSaving = false;
            return;
        }

        // NavigationException must escape uncaught — do NOT wrap in try/catch.
        // Blazor static-SSR converts it into the 302 redirect response.
        Navigation.NavigateTo("/venues");
    }

    // ── Community affiliation handler ───────────────────────────────────
    private async Task HandleAffiliationSaveAsync()
    {
        if (_viewerId is null || VenueId is null) return;

        _isSavingAffiliation = true;
        _affiliationFlashSuccess = "";
        _affiliationFlashError = "";

        Guid? communityId = null;
        if (!string.IsNullOrWhiteSpace(_affiliationModel.SelectedCommunityId))
        {
            if (!Guid.TryParse(_affiliationModel.SelectedCommunityId, out var parsed))
            {
                _affiliationFlashError = "Invalid community selection.";
                _isSavingAffiliation = false;
                return;
            }
            communityId = parsed;
        }

        var result = await VenueService.SetCommunityAffiliationAsync(
            VenueId.Value, communityId, _viewerId.Value);

        if (!result.Success)
        {
            _affiliationFlashError = result.ErrorMessage ?? "Could not update affiliation.";
            _isSavingAffiliation = false;
            return;
        }

        // Self-redirect so the updated state reloads cleanly through
        // OnInitializedAsync and the flash-success message shows after a
        // 302 round trip.
        Navigation.NavigateTo($"/venues/{VenueId}/edit?flash=affiliation-saved");
    }

    // ── Delete handler ──────────────────────────────────────────────────
    private async Task HandleDeleteAsync()
    {
        if (!Guid.TryParse(_deleteModel.VenueId, out var idToDelete))
        {
            _errorMessage = "Invalid venue identifier. Cannot delete.";
            return;
        }

        _isDeleting = true;
        _errorMessage = "";

        try
        {
            await VenueService.DeleteAsync(idToDelete);
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to delete the venue. Please try again.";
            Logger.LogWarning(ex, "Failed to delete venue {VenueId}.", idToDelete);
            _isDeleting = false;
            return;
        }

        // NavigationException must escape uncaught.
        Navigation.NavigateTo("/venues");
    }

    // ── Form models ─────────────────────────────────────────────────────

    private sealed class SaveVenueModel
    {
        [Required(ErrorMessage = "Venue name is required.")]
        [StringLength(80, MinimumLength = 2,
            ErrorMessage = "Name must be between 2 and 80 characters.")]
        public string Name { get; set; } = "";

        [StringLength(200, ErrorMessage = "Address must be 200 characters or fewer.")]
        public string Address { get; set; } = "";

        [StringLength(30, ErrorMessage = "Phone number must be 30 characters or fewer.")]
        public string PhoneNumber { get; set; } = "";

        public bool Private { get; set; }

        public Venue ToVenue(Guid id) => new()
        {
            VenueId     = id,
            Name        = Name,
            Address     = Address,
            PhoneNumber = PhoneNumber,
            Private     = Private
        };
    }

    private sealed class DeleteVenueModel
    {
        public string VenueId { get; set; } = "";
    }

    public sealed class AffiliationModel
    {
        /// <summary>
        /// Guid-as-string so an empty selection round-trips as an empty
        /// string rather than Guid.Empty.
        /// </summary>
        public string? SelectedCommunityId { get; set; }
    }
}
