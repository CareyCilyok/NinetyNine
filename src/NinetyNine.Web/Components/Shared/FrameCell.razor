@*
    FrameCell — a single column of the P&B score card grid (v2 visual refresh).

    Replaces the v1 circled-number badge with a numbered <PoolBall /> SVG and
    drives state classes from FrameStatus, retiring the inline if/else chain
    that lived in CellCssClass. FrameCell has no access to the parent Game,
    so the Status switch uses a 3-value classification (Active / Completed /
    Pending). The four-value form including Future lives in ScoreCardGrid,
    which has Game.CurrentFrameNumber on hand.

    Public parameter API is unchanged from the v1 cell:
        Frame              — the frame to render
        IsActive           — caller-supplied "is this the live frame" hint
                             (production sources set IsActive = Frame.IsActive,
                             tests sometimes diverge to exercise edge states)
        Mode               — View | Edit
        OnFrameActivated   — fired when the active+edit cell is clicked

    Two-signal state rule (never communicate state by color alone):
        Active    : gold border + glow shadow + translateY(-2px) + bright ball
        Completed : teal border + bright ball
        Pending   : dashed default-gray border + dimmed ball + opacity 0.6

    The button-vs-div wrapper still depends on Edit mode (only an active+edit
    cell is interactive); the visual-state class is now independent of mode,
    so an active cell in View mode also reads as "current".
*@

@if (IsInteractive)
{
    <button type="button"
            class="@CellCssClass"
            role="gridcell"
            aria-label="@AriaLabel"
            aria-current="true"
            @onclick="OnEnterScore">
        <div class="frame-cell-header">
            <span class="frame-number" aria-hidden="true"><PoolBall Number="@Frame.FrameNumber" Size="22" Dim="@IsBallDim" /></span>
        </div>

        <div class="frame-cell-row frame-cell-break-bonus">
            <span class="frame-cell-label" aria-hidden="true">Break</span>
            @if (Frame.IsCompleted)
            {
                <span class="score-value">@Frame.BreakBonus</span>
            }
            else
            {
                <span class="score-value score-placeholder">@EmDash</span>
            }
        </div>

        <div class="frame-cell-row frame-cell-ball-count">
            <span class="frame-cell-label" aria-hidden="true">Ball</span>
            @if (Frame.IsCompleted)
            {
                <span class="score-value">@Frame.BallCount</span>
            }
            else
            {
                <span class="score-value score-placeholder">@EmDash</span>
            }
        </div>

        <div class="frame-cell-row frame-cell-running-total">
            @if (Frame.IsCompleted)
            {
                <span class="score-value running-total">@Frame.RunningTotal</span>
            }
            else
            {
                <span class="score-value score-placeholder running-total">@EmDash</span>
            }
        </div>
    </button>
}
else
{
    <div class="@CellCssClass"
         role="gridcell"
         aria-label="@AriaLabel"
         aria-current="@AriaCurrent">
        <div class="frame-cell-header">
            <span class="frame-number" aria-hidden="true"><PoolBall Number="@Frame.FrameNumber" Size="22" Dim="@IsBallDim" /></span>
        </div>

        <div class="frame-cell-row frame-cell-break-bonus">
            <span class="frame-cell-label" aria-hidden="true">Break</span>
            @if (Frame.IsCompleted)
            {
                <span class="score-value">@Frame.BreakBonus</span>
            }
            else
            {
                <span class="score-value score-placeholder">@EmDash</span>
            }
        </div>

        <div class="frame-cell-row frame-cell-ball-count">
            <span class="frame-cell-label" aria-hidden="true">Ball</span>
            @if (Frame.IsCompleted)
            {
                <span class="score-value">@Frame.BallCount</span>
            }
            else
            {
                <span class="score-value score-placeholder">@EmDash</span>
            }
        </div>

        <div class="frame-cell-row frame-cell-running-total">
            @if (Frame.IsCompleted)
            {
                <span class="score-value running-total">@Frame.RunningTotal</span>
            }
            else
            {
                <span class="score-value score-placeholder running-total">@EmDash</span>
            }
        </div>
    </div>
}

@code {
    [Parameter] public Frame Frame { get; set; } = default!;
    [Parameter] public bool IsActive { get; set; }
    [Parameter] public ScoreCardMode Mode { get; set; } = ScoreCardMode.View;
    [Parameter] public EventCallback<Frame> OnFrameActivated { get; set; }

    private const string EmDash = "—";

    /// <summary>
    /// Visual classification for this cell. Resolution mirrors the
    /// FrameStatusExtensions.GetStatus rule, but uses the IsActive parameter
    /// (not Frame.IsActive) so callers can override activeness at the edge.
    /// </summary>
    private FrameStatus Status
    {
        get
        {
            if (Frame.IsCompleted) return FrameStatus.Completed;
            if (IsActive) return FrameStatus.Active;
            return FrameStatus.Pending;
        }
    }

    private bool IsInteractive => IsActive && Mode == ScoreCardMode.Edit;

    private bool IsBallDim => Status == FrameStatus.Pending;

    /// <summary>
    /// True when the completed frame hits the v2 per-frame max of 10 points
    /// (1 break bonus + 9 balls). Used to gold-accent the running total.
    /// </summary>
    private bool IsPerfectFrame =>
        Frame.IsCompleted && Frame.BreakBonus + Frame.BallCount == 10;

    private string CellCssClass
    {
        get
        {
            var baseClass = Status switch
            {
                FrameStatus.Active    => "frame-cell frame-cell-active",
                FrameStatus.Completed => "frame-cell frame-cell-completed",
                _                     => "frame-cell frame-cell-pending"
            };
            return IsPerfectFrame ? $"{baseClass} frame-cell-perfect" : baseClass;
        }
    }

    /// <summary>
    /// Mirror aria-current onto the non-interactive active cell so assistive
    /// tech in View mode still reads "current" — the button branch sets the
    /// attribute directly.
    /// </summary>
    private string? AriaCurrent =>
        Status == FrameStatus.Active ? "true" : null;

    private string AriaLabel
    {
        get
        {
            if (Frame.IsCompleted)
            {
                return $"Frame {Frame.FrameNumber}, Break Bonus {Frame.BreakBonus}, " +
                       $"Ball Count {Frame.BallCount}, Running Total {Frame.RunningTotal}. Completed.";
            }
            if (IsActive && Mode == ScoreCardMode.Edit)
            {
                return $"Frame {Frame.FrameNumber}, currently active. Press Enter to record score.";
            }
            if (IsActive)
            {
                return $"Frame {Frame.FrameNumber}, currently active, awaiting score.";
            }
            return $"Frame {Frame.FrameNumber}, not yet played.";
        }
    }

    private async Task OnEnterScore()
    {
        if (IsInteractive)
        {
            await OnFrameActivated.InvokeAsync(Frame);
        }
    }
}
