@*
    Modal dialog for entering frame scores.
    Validates: BreakBonus in {0,1}, BallCount in [0,10], FrameScore <= 11.

    Focus management is pure Blazor: we capture an ElementReference to
    the first interactive control and call FocusAsync() on first render
    after the dialog becomes visible. No IJSRuntime interop.
*@

@if (IsVisible)
{
    <div class="nn-dialog-backdrop"
         @onclick="Cancel"
         aria-hidden="true"></div>

    <div class="nn-dialog modal d-block"
         role="dialog"
         aria-modal="true"
         aria-labelledby="frame-dialog-title"
         tabindex="-1"
         @onkeydown="HandleKeyDown"
         @onkeydown:stopPropagation="true">
        <div class="nn-dialog__shell"
             @onclick:stopPropagation="true">
            <div class="nn-dialog__content">
                <header class="nn-dialog__header">
                    <h2 class="nn-dialog__title" id="frame-dialog-title">
                        Enter Score &mdash; Frame @FrameNumber
                    </h2>
                    <button type="button"
                            class="nn-dialog__close"
                            @onclick="Cancel"
                            aria-label="Close frame entry dialog">
                        <img class="nn-dialog__close-icon"
                             src="icons/phosphor/regular/x.svg"
                             alt=""
                             aria-hidden="true" />
                    </button>
                </header>

                <EditForm Model="_model" OnValidSubmit="Submit">
                    <DataAnnotationsValidator />

                    <div class="nn-dialog__body">
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="nn-dialog__alert nn-dialog__alert--danger" role="alert">
                                @_errorMessage
                            </div>
                        }

                        <div class="nn-dialog__field">
                            <label class="nn-dialog__label" id="break-bonus-label">
                                Break Bonus
                                <span class="nn-dialog__hint">0 = no bonus, 1 = bonus awarded</span>
                            </label>
                            <div class="nn-dialog__radio-group"
                                 role="radiogroup"
                                 aria-labelledby="break-bonus-label">
                                <input type="radio"
                                       class="nn-dialog__radio-input"
                                       name="breakBonus"
                                       id="bb-0"
                                       autocomplete="off"
                                       checked="@(_model.BreakBonus == 0)"
                                       @onchange="@(() => _model.BreakBonus = 0)"
                                       @ref="_firstInputRef" />
                                <label class="nn-dialog__radio" for="bb-0">
                                    <span class="nn-dialog__radio-dot" aria-hidden="true">0</span>
                                    <span>No</span>
                                </label>

                                <input type="radio"
                                       class="nn-dialog__radio-input"
                                       name="breakBonus"
                                       id="bb-1"
                                       autocomplete="off"
                                       checked="@(_model.BreakBonus == 1)"
                                       @onchange="@(() => _model.BreakBonus = 1)" />
                                <label class="nn-dialog__radio" for="bb-1">
                                    <span class="nn-dialog__radio-dot" aria-hidden="true">1</span>
                                    <span>Yes</span>
                                </label>
                            </div>
                        </div>

                        <div class="nn-dialog__field">
                            <label class="nn-dialog__label" for="ball-count">
                                Ball Count
                                <span class="nn-dialog__hint">0&ndash;10 &middot; 9-ball counts as 2</span>
                            </label>
                            <div class="nn-dialog__stepper">
                                <button type="button"
                                        class="nn-dialog__stepper-btn"
                                        @onclick="DecrementBallCount"
                                        aria-label="Decrease ball count"
                                        disabled="@(_model.BallCount <= 0)">
                                    <img class="nn-dialog__stepper-icon"
                                         src="icons/phosphor/regular/minus.svg"
                                         alt=""
                                         aria-hidden="true" />
                                </button>
                                <InputNumber id="ball-count"
                                             class="nn-dialog__stepper-input"
                                             @bind-Value="_model.BallCount"
                                             min="0" max="10"
                                             aria-describedby="ball-count-hint" />
                                <button type="button"
                                        class="nn-dialog__stepper-btn"
                                        @onclick="IncrementBallCount"
                                        aria-label="Increase ball count"
                                        disabled="@(_model.BallCount >= 10)">
                                    <img class="nn-dialog__stepper-icon"
                                         src="icons/phosphor/regular/plus.svg"
                                         alt=""
                                         aria-hidden="true" />
                                </button>
                            </div>
                            <div id="ball-count-hint" class="nn-dialog__hint">
                                Frame score will be @PreviewScore / 11
                            </div>
                            <ValidationMessage For="() => _model.BallCount" />
                        </div>

                        <div class="nn-dialog__field">
                            <label class="nn-dialog__label" for="frame-notes">
                                Notes <span class="nn-dialog__hint">(optional)</span>
                            </label>
                            <InputText id="frame-notes"
                                       class="nn-dialog__input"
                                       @bind-Value="_model.Notes"
                                       placeholder="e.g. scratched on break" />
                        </div>

                        <div class="nn-dialog__preview @(PreviewScore > 11 ? "nn-dialog__preview--error" : null)"
                             role="status"
                             aria-live="polite">
                            <span class="nn-dialog__preview-label">Frame score</span>
                            <span class="nn-dialog__preview-value">@PreviewScore</span>
                            <span class="nn-dialog__preview-max">/ 11</span>
                        </div>
                    </div>

                    <footer class="nn-dialog__footer">
                        <button type="button"
                                class="nn-dialog__btn nn-dialog__btn--ghost"
                                @onclick="Cancel">
                            Cancel
                        </button>
                        <button type="submit"
                                class="nn-dialog__btn nn-dialog__btn--primary"
                                disabled="@(PreviewScore > 11)">
                            Record Frame
                        </button>
                    </footer>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public int FrameNumber { get; set; }
    [Parameter] public EventCallback<FrameScoreInput> OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private FrameScoreInput _model = new();
    private string _errorMessage = "";
    private bool _wasVisible;
    private bool _shouldFocusFirstInput;
    private ElementReference _firstInputRef;

    private int PreviewScore => _model.BreakBonus + _model.BallCount;

    protected override void OnParametersSet()
    {
        if (IsVisible && !_wasVisible)
        {
            // Reset form when dialog opens for a new frame
            _model = new FrameScoreInput();
            _errorMessage = "";
            _shouldFocusFirstInput = true;
        }

        _wasVisible = IsVisible;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldFocusFirstInput && IsVisible)
        {
            _shouldFocusFirstInput = false;
            try
            {
                await _firstInputRef.FocusAsync();
            }
            catch
            {
                // Element may not yet exist in the DOM; safe to swallow.
            }
        }
    }

    private async Task Submit()
    {
        if (PreviewScore > 11)
        {
            _errorMessage = "Frame score cannot exceed 11 (Break Bonus + Ball Count <= 11).";
            return;
        }

        _errorMessage = "";
        await OnSubmit.InvokeAsync(_model);
    }

    private async Task Cancel()
    {
        await OnCancel.InvokeAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            await Cancel();
        }
    }

    private void IncrementBallCount()
    {
        if (_model.BallCount < 10)
        {
            _model.BallCount++;
        }
    }

    private void DecrementBallCount()
    {
        if (_model.BallCount > 0)
        {
            _model.BallCount--;
        }
    }

    public sealed class FrameScoreInput
    {
        [System.ComponentModel.DataAnnotations.Range(0, 1, ErrorMessage = "Break bonus must be 0 or 1.")]
        public int BreakBonus { get; set; }

        [System.ComponentModel.DataAnnotations.Range(0, 10, ErrorMessage = "Ball count must be between 0 and 10.")]
        public int BallCount { get; set; }

        public string? Notes { get; set; }
    }
}
