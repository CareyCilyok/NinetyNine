@*
    ScoreCardGrid — the full 9-frame P&B score card (v2 with in-cell controls).

    Desktop (>= 768px):
        9-column CSS grid. Each column is a v2 <FrameCell /> with
        in-cell Break checkbox, Ball button, and inline BallPicker.
        The active cell receives the in-flight buffer from the parent.

    Mobile (< 768px):
        Detail card showing the focused frame's stats (read-only —
        the in-cell controls live on the desktop grid; the mobile
        flow is read-oriented for now), plus a horizontally-
        scrolling picker strip of nine compact PoolBall chips.

    Below both layouts: a 4-pill summary strip with conditional teal
    glow on the Total tile when score >= 90.

    Parent API (CHANGED in v0.3.3):
        Game                : the game to render
        Mode                : View | Edit
        ActiveBreakBonus    : in-flight break bonus for the active cell
        ActiveBallsPocketed : in-flight ball selection for the active cell
        ActivePickerOpen    : is the active cell's BallPicker shown
        ActiveLiveRunningTotal : parent-computed running total to display
        OnBreakToggle       : fired by the active cell's Break button
        OnBallToggle        : fired with ball number from the picker
        OnBallsClear        : fired by the picker's Clear button
        OnBreakAndRun       : fired by the picker's "Break & run" shortcut
        OnPickerOpen        : fired when the active cell opens its picker
        OnPickerClose       : fired when the picker closes
*@

<div class="sc-wrapper" aria-label="Score card for current game">

    @* ============= DESKTOP: 9-column grid ============= *@
    <div class="sc-grid" role="grid" aria-label="Score card grid">
        @foreach (var frame in EnsureFrames())
        {
            var f = frame;
            var isActiveCell = f.IsActive;

            <FrameCell Frame="f"
                       IsActive="@isActiveCell"
                       Mode="Mode"
                       IsEfrenVariant="@(Game?.IsEfrenVariant == true)"
                       BreakBonus="@(isActiveCell && ActiveBreakBonus)"
                       BallsPocketed="@(isActiveCell ? ActiveBallsPocketed : null)"
                       IsPickerOpen="@(isActiveCell && ActivePickerOpen)"
                       LiveRunningTotal="@(isActiveCell ? ActiveLiveRunningTotal : null)"
                       OnBreakToggle="@(isActiveCell ? OnBreakToggle : EventCallback.Empty)"
                       OnBallToggle="@(isActiveCell ? OnBallToggle : EventCallback<int>.Empty)"
                       OnBallsClear="@(isActiveCell ? OnBallsClear : EventCallback.Empty)"
                       OnBreakAndRun="@(isActiveCell ? OnBreakAndRun : EventCallback.Empty)"
                       OnPickerOpen="@(isActiveCell ? OnPickerOpen : EventCallback.Empty)"
                       OnPickerClose="@(isActiveCell ? OnPickerClose : EventCallback.Empty)" />
        }
    </div>

    @* ============= MOBILE: detail card + picker strip ============= *@
    <div class="sc-mobile">
        @{
            var mobileFrame = EnsureFrames().FirstOrDefault(f => f.FrameNumber == _mobileActiveFrame)
                              ?? EnsureFrames().FirstOrDefault();
        }

        @if (mobileFrame is not null)
        {
            var mobileStatus = StatusFor(mobileFrame);
            var mobileStateClass = mobileStatus switch
            {
                FrameStatus.Active    => "sc-mobile-detail sc-mobile-detail-active",
                FrameStatus.Completed => "sc-mobile-detail sc-mobile-detail-completed",
                _                     => "sc-mobile-detail sc-mobile-detail-pending"
            };
            var isMobileBallDim = mobileStatus is FrameStatus.Pending or FrameStatus.Future;

            <div class="@mobileStateClass"
                 role="group"
                 aria-label="Frame @mobileFrame.FrameNumber detail">

                <div class="sc-mobile-detail-header">
                    <PoolBall Number="@mobileFrame.FrameNumber" Size="44" Dim="@isMobileBallDim" />
                    <div class="sc-mobile-detail-meta">
                        <div class="sc-mobile-detail-title">Frame @mobileFrame.FrameNumber</div>
                        <div class="sc-mobile-detail-status">@MobileStatusLabel(mobileFrame)</div>
                    </div>
                </div>

                <div class="sc-mobile-detail-stats">
                    <div class="sc-mobile-stat">
                        <span class="sc-mobile-stat-label">Break</span>
                        <span class="sc-mobile-stat-value">
                            @(mobileFrame.IsCompleted ? mobileFrame.BreakBonus.ToString() : EmDash)
                        </span>
                    </div>
                    <div class="sc-mobile-stat">
                        <span class="sc-mobile-stat-label">Ball</span>
                        <span class="sc-mobile-stat-value">
                            @(mobileFrame.IsCompleted ? mobileFrame.BallCount.ToString() : EmDash)
                        </span>
                    </div>
                    <div class="sc-mobile-stat sc-mobile-stat-total">
                        <span class="sc-mobile-stat-label">Total</span>
                        <span class="sc-mobile-stat-value">
                            @(mobileFrame.IsCompleted ? mobileFrame.RunningTotal.ToString() : EmDash)
                        </span>
                    </div>
                </div>
            </div>
        }

        <div class="sc-picker" role="tablist" aria-label="Frame picker">
            @foreach (var frame in EnsureFrames())
            {
                var f = frame;
                var isSelected = f.FrameNumber == _mobileActiveFrame;
                var status = StatusFor(f);
                var isBallDim = status is FrameStatus.Pending or FrameStatus.Future;
                var chipClass = "sc-picker-chip";
                if (isSelected) chipClass += " sc-picker-chip-selected";
                if (f.IsCompleted) chipClass += " sc-picker-chip-completed";
                if (f.IsActive) chipClass += " sc-picker-chip-active";

                <button type="button"
                        role="tab"
                        class="@chipClass"
                        aria-selected="@(isSelected ? "true" : "false")"
                        aria-label="@PickerAriaLabel(f)"
                        @onclick="() => SelectMobileFrame(f.FrameNumber)">
                    <PoolBall Number="@f.FrameNumber" Size="20" Dim="@isBallDim" />
                    <span class="sc-picker-chip-total" aria-hidden="true">
                        @(f.IsCompleted ? f.RunningTotal.ToString() : EmDash)
                    </span>
                </button>
            }
        </div>
    </div>

    @* ============= SUMMARY STRIP ============= *@
    @if (Game is not null)
    {
        <div class="@SummaryStripClass" aria-live="polite" aria-atomic="true">
            <div class="@SummaryTotalClass">
                <img src="icons/phosphor/regular/trophy.svg"
                     class="nn-icon sc-summary-icon" alt="" aria-hidden="true" />
                <div class="sc-summary-body">
                    <div class="sc-summary-label">Total</div>
                    <div class="sc-summary-value">
                        <span class="sc-summary-number">@Game.TotalScore</span>
                        <span class="sc-summary-suffix">/ 99</span>
                    </div>
                </div>
            </div>

            <div class="sc-summary-item">
                <img src="icons/phosphor/regular/chart-line-up.svg"
                     class="nn-icon sc-summary-icon" alt="" aria-hidden="true" />
                <div class="sc-summary-body">
                    <div class="sc-summary-label">Avg / Frame</div>
                    <div class="sc-summary-value">
                        <span class="sc-summary-number">@AverageFrameDisplay</span>
                    </div>
                </div>
            </div>

            <div class="sc-summary-item">
                <img src="icons/phosphor/regular/check.svg"
                     class="nn-icon sc-summary-icon" alt="" aria-hidden="true" />
                <div class="sc-summary-body">
                    <div class="sc-summary-label">Completed</div>
                    <div class="sc-summary-value">
                        <span class="sc-summary-number">@Game.CompletedFrames</span>
                        <span class="sc-summary-suffix">/ 9</span>
                    </div>
                </div>
            </div>

            <div class="sc-summary-item">
                <img src="icons/phosphor/regular/target.svg"
                     class="nn-icon sc-summary-icon" alt="" aria-hidden="true" />
                <div class="sc-summary-body">
                    <div class="sc-summary-label">Current</div>
                    <div class="sc-summary-value">
                        <span class="sc-summary-number">@CurrentFrameDisplay</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Game? Game { get; set; }
    [Parameter] public ScoreCardMode Mode { get; set; } = ScoreCardMode.View;

    // ── In-flight buffer (passed through to the active FrameCell) ────────────

    [Parameter] public bool ActiveBreakBonus { get; set; }
    [Parameter] public IReadOnlySet<int>? ActiveBallsPocketed { get; set; }
    [Parameter] public bool ActivePickerOpen { get; set; }
    [Parameter] public int? ActiveLiveRunningTotal { get; set; }

    // ── Events (forwarded to the active cell only) ───────────────────────────

    [Parameter] public EventCallback OnBreakToggle { get; set; }
    [Parameter] public EventCallback<int> OnBallToggle { get; set; }
    [Parameter] public EventCallback OnBallsClear { get; set; }
    [Parameter] public EventCallback OnBreakAndRun { get; set; }
    [Parameter] public EventCallback OnPickerOpen { get; set; }
    [Parameter] public EventCallback OnPickerClose { get; set; }

    private const string EmDash = "—";
    private const int TotalThresholdForGlow = 90;

    private int _mobileActiveFrame = 1;

    protected override void OnParametersSet()
    {
        var activeFrame = Game?.CurrentFrame;
        if (activeFrame is not null)
        {
            _mobileActiveFrame = activeFrame.FrameNumber;
        }
        else if (_mobileActiveFrame < 1 || _mobileActiveFrame > 9)
        {
            _mobileActiveFrame = 1;
        }
    }

    private IReadOnlyList<Frame> EnsureFrames()
    {
        if (Game is null) return Array.Empty<Frame>();

        if (!Game.Frames.Any())
        {
            return Enumerable.Range(1, 9)
                .Select(n => new Frame { FrameNumber = n, GameId = Game.GameId })
                .ToList();
        }

        return Game.Frames;
    }

    private FrameStatus StatusFor(Frame frame) => frame.GetStatus(Game?.CurrentFrameNumber);

    private string SummaryTotalClass =>
        Game is not null && Game.TotalScore >= TotalThresholdForGlow
            ? "sc-summary-item sc-summary-total sc-summary-total--threshold"
            : "sc-summary-item sc-summary-total";

    // When the active player's Game is the Efren variant, illuminate the
    // whole stat-pill row with a subtle gold ring + glow. In single-player
    // mode the only player is always the active shooter, so the strip
    // glows whenever Game.IsEfrenVariant. Multi-player (v0.5.x) will gate
    // this through ScoreCardGrid being rendered for the active section.
    private string SummaryStripClass =>
        Game is not null && Game.IsEfrenVariant
            ? "sc-summary sc-summary--efren"
            : "sc-summary";

    private void SelectMobileFrame(int frameNumber) => _mobileActiveFrame = frameNumber;

    private string AverageFrameDisplay =>
        Game is null || Game.CompletedFrames == 0
            ? EmDash
            : Game.AverageScore.ToString("F1");

    private string CurrentFrameDisplay
    {
        get
        {
            if (Game is null) return EmDash;
            if (Game.IsCompleted) return "Done";
            var n = Game.CurrentFrame?.FrameNumber ?? Game.CurrentFrameNumber;
            return n >= 1 ? n.ToString() : EmDash;
        }
    }

    private static string MobileStatusLabel(Frame frame)
    {
        if (frame.IsCompleted) return "Completed";
        if (frame.IsActive) return "Active";
        return "Not yet played";
    }

    private static string PickerAriaLabel(Frame frame)
    {
        if (frame.IsCompleted)
            return $"Frame {frame.FrameNumber}, completed, running total {frame.RunningTotal}";
        if (frame.IsActive)
            return $"Frame {frame.FrameNumber}, currently active";
        return $"Frame {frame.FrameNumber}, not yet played";
    }
}
