@* Segmented button group for picking a pool table size. *@

<div class="nn-picker"
     role="radiogroup"
     aria-label="Table size">
    @for (var i = 0; i < _sizes.Length; i++)
    {
        var index = i;
        var s = _sizes[index];
        var isSelected = Value == s;
        <button type="button"
                class="nn-picker__option @(isSelected ? "nn-picker__option--selected" : null)"
                role="radio"
                aria-checked="@(isSelected ? "true" : "false")"
                tabindex="@(isSelected ? 0 : -1)"
                @onclick="() => OnChange(s)"
                @onkeydown="e => OnKeyDown(e, index)">
            @Label(s)
        </button>
    }
</div>

@code {
    [Parameter] public TableSize Value { get; set; } = TableSize.SevenFoot;
    [Parameter] public EventCallback<TableSize> ValueChanged { get; set; }

    private static readonly TableSize[] _sizes =
        Enum.GetValues<TableSize>().Where(s => s != TableSize.Unknown).ToArray();

    private async Task OnChange(TableSize s)
    {
        if (Value == s) return;
        await ValueChanged.InvokeAsync(s);
    }

    private async Task OnKeyDown(KeyboardEventArgs e, int currentIndex)
    {
        int nextIndex = currentIndex;
        switch (e.Key)
        {
            case "ArrowRight":
            case "ArrowDown":
                nextIndex = (currentIndex + 1) % _sizes.Length;
                break;
            case "ArrowLeft":
            case "ArrowUp":
                nextIndex = (currentIndex - 1 + _sizes.Length) % _sizes.Length;
                break;
            case "Home":
                nextIndex = 0;
                break;
            case "End":
                nextIndex = _sizes.Length - 1;
                break;
            default:
                return;
        }

        if (nextIndex != currentIndex)
        {
            await ValueChanged.InvokeAsync(_sizes[nextIndex]);
        }
    }

    private static string Label(TableSize s) => s switch
    {
        TableSize.SixFoot => "6 ft",
        TableSize.SevenFoot => "7 ft",
        TableSize.NineFoot => "9 ft",
        TableSize.TenFoot => "10 ft",
        _ => s.ToString()
    };
}
